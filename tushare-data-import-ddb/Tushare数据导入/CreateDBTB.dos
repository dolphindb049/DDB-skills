def createQuarterStockCashflow(){
    dbName = "dfs://quarter_factor"
    tbName = "quarter_stock_cashflow"
    if(!existsDatabase(dbName)){
        EasyTushareLog("Database of " + dbName + " does not exist, please create database first!")
    }
    else{
        db = database(dbName)
        schemaTB = table(
            array(SYMBOL, 0) as ts_code,
            array(DATE, 0) as ann_date,
            array(DATE, 0) as f_ann_date,
            array(DATE, 0) as end_date,
            array(SYMBOL, 0) as comp_type,
            array(SYMBOL, 0) as report_type,
            array(SYMBOL, 0) as end_type,
            array(DOUBLE, 0) as net_profit,
            array(DOUBLE, 0) as finan_exp,
            array(DOUBLE, 0) as c_fr_sale_sg,
            array(DOUBLE, 0) as recp_tax_rends,
            array(DOUBLE, 0) as n_depos_incr_fi,
            array(DOUBLE, 0) as n_incr_loans_cb,
            array(DOUBLE, 0) as n_inc_borr_oth_fi,
            array(DOUBLE, 0) as prem_fr_orig_contr,
            array(DOUBLE, 0) as n_incr_insured_dep,
            array(DOUBLE, 0) as n_reinsur_prem,
            array(DOUBLE, 0) as n_incr_disp_tfa,
            array(DOUBLE, 0) as ifc_cash_incr,
            array(DOUBLE, 0) as n_incr_disp_faas,
            array(DOUBLE, 0) as n_incr_loans_oth_bank,
            array(DOUBLE, 0) as n_cap_incr_repur,
            array(DOUBLE, 0) as c_fr_oth_operate_a,
            array(DOUBLE, 0) as c_inf_fr_operate_a,
            array(DOUBLE, 0) as c_paid_goods_s,
            array(DOUBLE, 0) as c_paid_to_for_empl,
            array(DOUBLE, 0) as c_paid_for_taxes,
            array(DOUBLE, 0) as n_incr_clt_loan_adv,
            array(DOUBLE, 0) as n_incr_dep_cbob,
