            array(DOUBLE, 0) as cost_fin_assets,
            array(DOUBLE, 0) as fair_value_fin_assets,
            array(DOUBLE, 0) as contract_assets,
            array(DOUBLE, 0) as contract_liab,
            array(DOUBLE, 0) as accounts_receiv_bill,
            array(DOUBLE, 0) as accounts_pay,
            array(DOUBLE, 0) as oth_rcv_total,
            array(DOUBLE, 0) as fix_assets_total,
            array(DOUBLE, 0) as cip_total,
            array(DOUBLE, 0) as oth_pay_total,
            array(DOUBLE, 0) as long_pay_total,
            array(DOUBLE, 0) as debt_invest,
            array(DOUBLE, 0) as oth_debt_invest,
            array(SYMBOL, 0) as update_flag,
            array(TIMESTAMP, 0) as update_time
        )
        db.createPartitionedTable(
            table = schemaTB,
            tableName = tbName, 
            partitionColumns=`ann_date,
            sortColumns=`ts_code`ann_date,
            keepDuplicates=LAST
        )
        go 
