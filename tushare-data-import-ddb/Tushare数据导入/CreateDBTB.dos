module DolphinDBModules::EasyTushare::createDBTB

/* 
*  @ brief  
*  This module is used to create DFS tables for stock data.
*  @ Author: DolphinDB
*  @ Last modification time: 2025.05.07
*  @ DolphinDB server version: 3.00.2.3
*/

use DolphinDBModules::EasyTushare::utils

def createDB(){
    drop database if exists "dfs://basic_factor"
    drop database if exists "dfs://day_factor"
    drop database if exists "dfs://week_factor"
    drop database if exists "dfs://month_factor"
    drop database if exists "dfs://quarter_factor"
    drop database if exists "dfs://year_factor"
    database("dfs://basic_factor", RANGE, date(datetimeAdd(1990.01M,0..100*12,'M')), engine="TSDB")
    database("dfs://day_factor", RANGE, date(datetimeAdd(1990.01M,0..100*12,'M')), engine="TSDB")
    database("dfs://week_factor", RANGE, date(datetimeAdd(1990.01M,0..100*12,'M')), engine="TSDB")
    database("dfs://month_factor", RANGE, date(datetimeAdd(1990.01M,0..100*12,'M')), engine="TSDB")
    database("dfs://quarter_factor", RANGE, date(datetimeAdd(1990.01M,0..100*12,'M')), engine="TSDB")
    database("dfs://year_factor", RANGE, date(datetimeAdd(1990.01M,0..100*12,'M')), engine="TSDB")
}
/*
*  @FunctionName: createStockBasic
*  @Brief: Create a DFS table for stock basic data
*  @Param: None
*  @Return: None
*  @SampleUsage: createStockBasic()
*/
// q? 为什么其他字段不需要了
def createStockBasic(){
    dbName = "dfs://basic_factor"
    tbName = "stock_basic"
    if(existsDatabase(dbName)){
        db = database(dbName)
        schemaTB = table(
            array(SYMBOL, 0) as ts_code,
            array(SYMBOL, 0) as symbol,
            array(SYMBOL, 0) as name,
            array(SYMBOL, 0) as area,
            array(SYMBOL, 0) as industry,
            array(SYMBOL, 0) as market,
            array(DATE, 0) as list_date,
            array(STRING, 0) as act_name,
            array(SYMBOL, 0) as act_ent_type,
            array(TIMESTAMP, 0) as update_time
        )
        db.createTable(
            table = schemaTB,
            tableName = tbName,
            sortColumns=`ts_code,
            keepDuplicates=ALL
        )
        go
        columnComments = dict(STRING, STRING)
        columnComments["ts_code"] = "TS股票代码"
        columnComments["symbol"] = "股票代码"
        columnComments["name"] = "股票名称"
        columnComments["area"] = "所在地域"
        columnComments["industry"] = "所属行业"
        columnComments["market"] = "市场类型"
        columnComments["list_date"] = "上市日期"
        columnComments["act_name"] = "实际控制人名称"
        columnComments["act_ent_type"] = "实际控制人企业性质"
        columnComments["update_time"] = "更新时间"
        setColumnComment(loadTable(dbName, tbName), columnComments)
        // EasyTushareLog("Table of " + tbName + " created successfully!")
    }else{
        EasyTushareLog("Database of " + dbName + " does not exist, please create database first!")
    }
}

/*
*  @FunctionName: createStockPremarket
*  @Brief: Create a DFS table for stock premarket data
*  @Param: None
*  @Return: None
*  @SampleUsage: createStockPremarket()
*/
def createStockPremarket(){
    dbName = "dfs://basic_factor"
    tbName = "stock_premarket"
    if(!existsDatabase(dbName)){
        EasyTushareLog("Database of " + dbName + " does not exist, please create database first!")
    }
    else{
        db = database(dbName)
        schemaTB = table(
            array(SYMBOL, 0) as ts_code,
            array(DATE, 0) as trade_date,
            array(DOUBLE, 0) as total_share,
            array(DOUBLE, 0) as float_share,
            array(DOUBLE, 0) as pre_close,
            array(DOUBLE, 0) as up_limit,
            array(DOUBLE, 0) as down_limit,
            array(TIMESTAMP, 0) as update_time
        )
        db.createPartitionedTable(
            table = schemaTB,
            tableName = tbName, 
            partitionColumns=`trade_date,
            sortColumns=`ts_code`trade_date,
            keepDuplicates=LAST
        )
        go 
        columnComments = dict(STRING, STRING)
        columnComments["ts_code"] = "TS股票代码"
        columnComments["trade_date"] = "交易日期"
        columnComments["total_share"] = "总股本(万股)"
        columnComments["float_share"] = "流通股本(万股)"
        columnComments["pre_close"] = "昨收盘价"
        columnComments["up_limit"] = "涨停价"
        columnComments["down_limit"] = "跌停价"
        columnComments["update_time"] = "更新时间"
        setColumnComment(loadTable(dbName,tbName), columnComments)
        EasyTushareLog("Table of " + tbName + " created successfully!")
    }
}

