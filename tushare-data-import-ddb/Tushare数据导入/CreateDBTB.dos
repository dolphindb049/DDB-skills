            array(DOUBLE, 0) as total_share, 
            array(DOUBLE, 0) as total_assets, 
            array(DOUBLE, 0) as liquid_assets, 
            array(DOUBLE, 0) as fixed_assets, 
            array(DOUBLE, 0) as reserved, 
            array(DOUBLE, 0) as reserved_pershare, 
            array(DOUBLE, 0) as eps, 
            array(DOUBLE, 0) as bvps, 
            array(DOUBLE, 0) as pb, 
            array(DATE, 0) as list_date, 
            array(DOUBLE, 0) as undp, 
            array(DOUBLE, 0) as per_undp, 
            array(DOUBLE, 0) as rev_yoy, 
            array(DOUBLE, 0) as profit_yoy, 
            array(DOUBLE, 0) as gpr, 
            array(DOUBLE, 0) as npr, 
            array(INT, 0) as holder_num, 
            array(TIMESTAMP, 0) as update_time
        )
        db.createPartitionedTable(
            table = schemaTB,
            tableName = tbName, 
            partitionColumns=`trade_date,
            sortColumns=`ts_code`trade_date,
            keepDuplicates=LAST
        )
        go
        columnComments = dict(STRING, STRING)
        columnComments["ts_code"] = "TS股票代码"
        columnComments["trade_date"] = "交易日期"
        columnComments["name"] = "股票名称"
        columnComments["industry"] = "所属行业"
        columnComments["area"] = "所在地域"
        columnComments["pe"] = "市盈率"
        columnComments["float_share"] = "流通股本(万股)"
        columnComments["total_share"] = "总股本(万股)"
        columnComments["total_assets"] = "总资产(万元)"
        columnComments["liquid_assets"] = "流动资产(万元)"
        columnComments["fixed_assets"] = "固定资产(万元)"
        columnComments["reserved"] = "公积金"
        columnComments["reserved_pershare"] = "每股公积金"
        columnComments["eps"] = "每股收益"
        columnComments["bvps"] = "每股净资产"
        columnComments["pb"] = "市净率"
        columnComments["list_date"] = "上市日期"
        columnComments["undp"] = "未分配利润"
        columnComments["per_undp"] = "每股未分配利润"
        columnComments["rev_yoy"] = "收入同比(%)"
        columnComments["profit_yoy"] = "利润同比(%)"
        columnComments["gpr"] = "毛利率(%)"
        columnComments["npr"] = "净利润率(%)"
        columnComments["holder_num"] = "股东人数"
        columnComments["update_time"] = "更新时间"    
        setColumnComment(loadTable(dbName,tbName), columnComments)
        EasyTushareLog("Table of " + tbName + " created successfully!")
    }
}

/*
*  @FunctionName: createStockDaily
*  @Brief: Create a DFS table for stock daily data
*  @Param: None
*  @Return: None
