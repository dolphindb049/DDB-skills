def createQuarterStockBalancesheet(){
    dbName = "dfs://quarter_factor"
    tbName = "quarter_stock_balancesheet"
    if(!existsDatabase(dbName)){
        EasyTushareLog("Database of " + dbName + " does not exist, please create database first!")
    }
    else{
        db = database(dbName)
        schemaTB = table(
            array(SYMBOL, 0) as ts_code,
            array(DATE, 0) as ann_date,
            array(DATE, 0) as f_ann_date,
            array(DATE, 0) as end_date,
            array(SYMBOL, 0) as report_type,
            array(SYMBOL, 0) as comp_type,
            array(SYMBOL, 0) as end_type,
            array(DOUBLE, 0) as total_share,
            array(DOUBLE, 0) as cap_rese,
            array(DOUBLE, 0) as undistr_porfit,
            array(DOUBLE, 0) as surplus_rese,
            array(DOUBLE, 0) as special_rese,
            array(DOUBLE, 0) as money_cap,
            array(DOUBLE, 0) as trad_asset,
            array(DOUBLE, 0) as notes_receiv,
            array(DOUBLE, 0) as accounts_receiv,
            array(DOUBLE, 0) as oth_receiv,
            array(DOUBLE, 0) as prepayment,
            array(DOUBLE, 0) as div_receiv,
            array(DOUBLE, 0) as int_receiv,
            array(DOUBLE, 0) as inventories,
            array(DOUBLE, 0) as amor_exp,
            array(DOUBLE, 0) as nca_within_1y,
            array(DOUBLE, 0) as sett_rsrv,
            array(DOUBLE, 0) as loanto_oth_bank_fi,
            array(DOUBLE, 0) as premium_receiv,
            array(DOUBLE, 0) as reinsur_receiv,
            array(DOUBLE, 0) as reinsur_res_receiv,
            array(DOUBLE, 0) as pur_resale_fa,
            array(DOUBLE, 0) as oth_cur_assets,
            array(DOUBLE, 0) as total_cur_assets,
            array(DOUBLE, 0) as fa_avail_for_sale,
            array(DOUBLE, 0) as htm_invest,
            array(DOUBLE, 0) as lt_eqt_invest,
            array(DOUBLE, 0) as invest_real_estate,
            array(DOUBLE, 0) as time_deposits,
            array(DOUBLE, 0) as oth_assets,
            array(DOUBLE, 0) as lt_rec,
            array(DOUBLE, 0) as fix_assets,
            array(DOUBLE, 0) as cip,
            array(DOUBLE, 0) as const_materials,
            array(DOUBLE, 0) as fixed_assets_disp,
            array(DOUBLE, 0) as produc_bio_assets,
            array(DOUBLE, 0) as oil_and_gas_assets,
            array(DOUBLE, 0) as intan_assets,
            array(DOUBLE, 0) as r_and_d,
            array(DOUBLE, 0) as goodwill,
            array(DOUBLE, 0) as lt_amor_exp,
