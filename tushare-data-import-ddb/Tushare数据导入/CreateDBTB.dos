def createStockIndexBasic(){
    dbName = "dfs://basic_factor"
    tbName = "stock_index_basic"
    if(!existsDatabase(dbName)){
        EasyTushareLog("Database of " + dbName + " does not exist, please create database first!")
    }
    else{
        db = database(dbName)
        schemaTB = table(
            array(SYMBOL, 0) as ts_code,
            array(SYMBOL, 0) as name,
            array(SYMBOL, 0) as fullname,
            array(SYMBOL, 0) as market,
            array(SYMBOL, 0) as publisher,
            array(SYMBOL, 0) as index_type,
            array(SYMBOL, 0) as category,
            array(DATE, 0) as base_date,
            array(DOUBLE, 0) as base_point,
            array(DATE, 0) as list_date,
            array(SYMBOL, 0) as weight_rule,
            array(STRING, 0) as desc,
            array(DATE, 0) as exp_date,
            array(TIMESTAMP, 0) as update_time
        )
        db.createTable(
            table = schemaTB,
            tableName = tbName, 
            sortColumns=`ts_code,
            keepDuplicates=ALL
        )
        go 
        columnComments = dict(STRING, STRING)
        columnComments["ts_code"] = "TS代码"
        columnComments["name"] = "简称"
        columnComments["fullname"] = "指数全称"
        columnComments["market"] = "市场"
        columnComments["publisher"] = "发布方"
        columnComments["index_type"] = "指数风格"
        columnComments["category"] = "指数类别"
        columnComments["base_date"] = "基期"
        columnComments["base_point"] = "基点"
        columnComments["list_date"] = "发布日期"
        columnComments["weight_rule"] = "加权方式"
        columnComments["desc"] = "描述"
        columnComments["exp_date"] = "终止日期"
        columnComments["update_time"] = "更新时间"
        setColumnComment(loadTable(dbName,tbName), columnComments)
        EasyTushareLog("Table of " + tbName + " created successfully!")
    }
}

