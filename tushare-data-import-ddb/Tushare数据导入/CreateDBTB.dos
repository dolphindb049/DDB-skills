def createStockCashflow(){
    dbName = "dfs://day_factor"
    tbName = "stock_cashflow"
    if(!existsDatabase(dbName)){
        EasyTushareLog("Database of " + dbName + " does not exist, please create database first!")
    }
    else{
        db = database(dbName)
        schemaTB = table(
            array(SYMBOL, 0) as ts_code,
            array(DATE, 0) as ann_date,
            array(DATE, 0) as f_ann_date,
            array(DATE, 0) as end_date,
            array(SYMBOL, 0) as comp_type,
            array(SYMBOL, 0) as report_type,
            array(SYMBOL, 0) as end_type,
            array(DOUBLE, 0) as net_profit,
            array(DOUBLE, 0) as finan_exp,
            array(DOUBLE, 0) as c_fr_sale_sg,
            array(DOUBLE, 0) as recp_tax_rends,
            array(DOUBLE, 0) as n_depos_incr_fi,
            array(DOUBLE, 0) as n_incr_loans_cb,
            array(DOUBLE, 0) as n_inc_borr_oth_fi,
            array(DOUBLE, 0) as prem_fr_orig_contr,
            array(DOUBLE, 0) as n_incr_insured_dep,
            array(DOUBLE, 0) as n_reinsur_prem,
            array(DOUBLE, 0) as n_incr_disp_tfa,
            array(DOUBLE, 0) as ifc_cash_incr,
            array(DOUBLE, 0) as n_incr_disp_faas,
            array(DOUBLE, 0) as n_incr_loans_oth_bank,
            array(DOUBLE, 0) as n_cap_incr_repur,
            array(DOUBLE, 0) as c_fr_oth_operate_a,
            array(DOUBLE, 0) as c_inf_fr_operate_a,
            array(DOUBLE, 0) as c_paid_goods_s,
            array(DOUBLE, 0) as c_paid_to_for_empl,
            array(DOUBLE, 0) as c_paid_for_taxes,
            array(DOUBLE, 0) as n_incr_clt_loan_adv,
            array(DOUBLE, 0) as n_incr_dep_cbob,
            array(DOUBLE, 0) as c_pay_claims_orig_inco,
            array(DOUBLE, 0) as pay_handling_chrg,
            array(DOUBLE, 0) as pay_comm_insur_plcy,
            array(DOUBLE, 0) as oth_cash_pay_oper_act,
            array(DOUBLE, 0) as st_cash_out_act,
            array(DOUBLE, 0) as n_cashflow_act,
            array(DOUBLE, 0) as oth_recp_ral_inv_act,
            array(DOUBLE, 0) as c_disp_withdrwl_invest,
            array(DOUBLE, 0) as c_recp_return_invest,
            array(DOUBLE, 0) as n_recp_disp_fiolta,
            array(DOUBLE, 0) as n_recp_disp_sobu,
            array(DOUBLE, 0) as stot_inflows_inv_act,
            array(DOUBLE, 0) as c_pay_acq_const_fiolta,
            array(DOUBLE, 0) as c_paid_invest,
            array(DOUBLE, 0) as n_disp_subs_oth_biz,
            array(DOUBLE, 0) as oth_pay_ral_inv_act,
            array(DOUBLE, 0) as n_incr_pledge_loan,
            array(DOUBLE, 0) as stot_out_inv_act,
            array(DOUBLE, 0) as n_cashflow_inv_act,
            array(DOUBLE, 0) as c_recp_borrow,
            array(DOUBLE, 0) as proc_issue_bonds,
            array(DOUBLE, 0) as oth_cash_recp_ral_fnc_act,
            array(DOUBLE, 0) as stot_cash_in_fnc_act,
            array(DOUBLE, 0) as free_cashflow,
            array(DOUBLE, 0) as c_prepay_amt_borr,
            array(DOUBLE, 0) as c_pay_dist_dpcp_int_exp,
            array(DOUBLE, 0) as incl_dvd_profit_paid_sc_ms,
            array(DOUBLE, 0) as oth_cashpay_ral_fnc_act,
            array(DOUBLE, 0) as stot_cashout_fnc_act,
            array(DOUBLE, 0) as n_cash_flows_fnc_act,
            array(DOUBLE, 0) as eff_fx_flu_cash,
            array(DOUBLE, 0) as n_incr_cash_cash_equ,
            array(DOUBLE, 0) as c_cash_equ_beg_period,
            array(DOUBLE, 0) as c_cash_equ_end_period,
            array(DOUBLE, 0) as c_recp_cap_contrib,
            array(DOUBLE, 0) as incl_cash_rec_saims,
            array(DOUBLE, 0) as uncon_invest_loss,
            array(DOUBLE, 0) as prov_depr_assets,
            array(DOUBLE, 0) as depr_fa_coga_dpba,
            array(DOUBLE, 0) as amort_intang_assets,
            array(DOUBLE, 0) as lt_amort_deferred_exp,
            array(DOUBLE, 0) as decr_deferred_exp,
            array(DOUBLE, 0) as incr_acc_exp,
            array(DOUBLE, 0) as loss_disp_fiolta,
            array(DOUBLE, 0) as loss_scr_fa,
            array(DOUBLE, 0) as loss_fv_chg,
            array(DOUBLE, 0) as invest_loss,
            array(DOUBLE, 0) as decr_def_inc_tax_assets,
            array(DOUBLE, 0) as incr_def_inc_tax_liab,
            array(DOUBLE, 0) as decr_inventories,
