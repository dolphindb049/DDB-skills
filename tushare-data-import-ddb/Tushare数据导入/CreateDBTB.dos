            array(DOUBLE, 0) as incr_oper_payable,
            array(DOUBLE, 0) as others,
            array(DOUBLE, 0) as im_net_cashflow_oper_act,
            array(DOUBLE, 0) as conv_debt_into_cap,
            array(DOUBLE, 0) as conv_copbonds_due_within_1y,
            array(DOUBLE, 0) as fa_fnc_leases,
            array(DOUBLE, 0) as im_n_incr_cash_equ,
            array(DOUBLE, 0) as net_dism_capital_add,
            array(DOUBLE, 0) as net_cash_rece_sec,
            array(DOUBLE, 0) as credit_impa_loss,
            array(DOUBLE, 0) as use_right_asset_dep,
            array(DOUBLE, 0) as oth_loss_asset,
            array(DOUBLE, 0) as end_bal_cash,
            array(DOUBLE, 0) as beg_bal_cash,
            array(DOUBLE, 0) as end_bal_cash_equ,
            array(DOUBLE, 0) as beg_bal_cash_equ,
            array(SYMBOL, 0) as update_flag,
            array(TIMESTAMP, 0) as update_time
        )
        db.createPartitionedTable(
            table = schemaTB,
            tableName = tbName, 
            partitionColumns=`ann_date,
            sortColumns=`ts_code`ann_date,
            keepDuplicates=LAST
        )
        go 
        columnComments = dict(STRING, STRING)
        columnComments["ts_code"] = "TS股票代码"
        columnComments["ann_date"] = "公告日期"
        columnComments["f_ann_date"] = "实际公告日期"
