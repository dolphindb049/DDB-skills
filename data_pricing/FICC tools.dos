示例二：计算NPV和现金流
instrument = "{\"productType\": \"Swap\", \"swapType\": \"IrSwap\", \"irSwapType\": \"IrFixedFloatingSwap\", \"version\": 0, \"start\": \"2021.05.17\", \"maturity\": \"2023.05.17\", \"frequency\": \"Quarterly\", \"fixedRate\": 0.022125, \"calendar\": \"CFET\", \"fixedDayCountConvention\": \"Actual365\", \"floatingDayCountConvention\": \"Actual365\", \"payReceive\": \"Pay\", \"iborIndex\": \"FR_007\", \"spread\": 0.0000, \"notional\": [\"CNY\", 100000000]}"
pricingDate = "2022.06.10"
discountCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"version\": 0, \"referenceDate\": \"2022.06.10\", \"currency\": \"CNY\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"CubicHermiteSpline\", \"extrapMethod\": \"Flat\", \"frequency\": \"Quarterly\", \"dates\": [\"2022.06.13\", \"2022.06.17\", \"2022.06.24\", \"2022.07.13\", \"2022.09.13\", \"2022.12.13\", \"2023.03.13\", \"2023.06.13\", \"2024.06.13\", \"2025.06.13\", \"2026.06.13\"], \"values\": [0.0144, 0.0162, 0.0160, 0.017479, 0.018598, 0.019764, 0.020526, 0.020992, 0.022537, 0.024054, 0.025581]}"
forwardCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"version\": 0, \"referenceDate\": \"2022.06.10\", \"currency\": \"CNY\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"CubicHermiteSpline\", \"extrapMethod\": \"Flat\", \"frequency\": \"Quarterly\", \"dates\": [\"2022.06.13\", \"2022.06.17\", \"2022.06.24\", \"2022.07.13\", \"2022.09.13\", \"2022.12.13\", \"2023.03.13\", \"2023.06.13\", \"2024.06.13\", \"2025.06.13\", \"2026.06.13\"], \"values\": [0.0144, 0.0162, 0.0160, 0.017479, 0.018598, 0.019764, 0.020526, 0.020992, 0.022537, 0.024054, 0.025581]}"
assetPriceCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"AssetPriceCurve\", \"version\": 0, \"referenceDate\": \"2022.05.15\", \"currency\": \"CNY\", \"dates\": [\"2022.05.16\", \"2022.05.23\", \"2022.05.30\", \"2022.06.06\"], \"values\": [0.0165, 0.016, 0.0185, 0.0168]}"
setting = "{\"calcCashFlow\": true}"
'

def ir_fixed_floating_swap_pricer_wrapper(instrument, pricingDate, discountCurve, forwardCurve, assetPriceCurve, setting) {
    // 解析工具
    inst = parseInstrument(fromStdJson(instrument))
    
    // 转换日期参数
    pricingDateObj = date(pricingDate)
    
    // 解析曲线
    discountCurveObj = parseMktData(fromStdJson(discountCurve))
    forwardCurveObj = parseMktData(fromStdJson(forwardCurve))
    assetPriceCurveObj = parseMktData(fromStdJson(assetPriceCurve))
    
    // 处理 setting 参数
    if (setting == "" || isNull(setting)) {
        return irFixedFloatingSwapPricer(inst, pricingDateObj, discountCurveObj, forwardCurveObj, assetPriceCurveObj)
    } else {
        settingObj = fromStdJson(setting)
        return irFixedFloatingSwapPricer(inst, pricingDateObj, discountCurveObj, forwardCurveObj, assetPriceCurveObj, settingObj)
    }
}

if (`ir_fixed_floating_swap_pricer in (exec name from listMCPTools())) {
    updateMCPTool(`ir_fixed_floating_swap_pricer, ir_fixed_floating_swap_pricer_wrapper,
        `instrument`pricingDate`discountCurve`forwardCurve`assetPriceCurve`setting,
        ["STRING", "TEMPORAL", "STRING", "STRING", "STRING", "STRING"],
        description_ir_swap_pricer)
} else {
    addMCPTool(`ir_fixed_floating_swap_pricer, ir_fixed_floating_swap_pricer_wrapper,
        `instrument`pricingDate`discountCurve`forwardCurve`assetPriceCurve`setting,
        ["STRING", "TEMPORAL", "STRING", "STRING", "STRING", "STRING"],
        description_ir_swap_pricer)
}

publishMCPTools(`ir_fixed_floating_swap_pricer)


// fxForwardPricer MCP 工具
description_fx_forward_pricer = '
基于给定的即期汇率、本币与外币的贴现曲线，以及定价日期，计算外汇远期合约的净现值（NPV）。

参数说明：
- instrument: STRING，JSON格式的外汇远期定义，包含以下字段：
  * productType: STRING，固定填 "Forward"
  * forwardType: STRING，固定填 "FxForward"
  * version: INT，版本号，默认值 0
  * expiry: DATE，到期日
  * delivery: DATE，交割日
  * currencyPair: STRING，货币对，如 "USDCNY"
  * direction: STRING，交易方向，可选值："Buy"（买入）、"Sell"（卖出）
  * notional: ARRAY，名义本金，格式为 [货币, 金额]，如 ["USD", 1000000]
  * strike: DOUBLE，执行汇率

- pricingDate: TEMPORAL，定价日期

- spot: DOUBLE，即期汇率

- domesticCurve: STRING，JSON格式的本币贴现曲线定义，包含以下字段：
  * mktDataType: STRING，固定填 "Curve"
  * curveType: STRING，固定填 "IrYieldCurve"
  * referenceDate: TEMPORAL，参考日期
  * currency: STRING，本币货币代码，如 "CNY"
  * dayCountConvention: STRING，日期计数惯例，如 "Actual365"
  * compounding: STRING，复利类型，如 "Continuous"
  * interpMethod: STRING，内插方法，如 "Linear"
  * extrapMethod: STRING，外插方法，如 "Flat"
  * frequency: STRING，计息频率，如 "Annual"
  * dates: DATE[]，曲线节点日期
  * values: DOUBLE[]，曲线节点利率值

- foreignCurve: STRING，JSON格式的外币贴现曲线定义，结构同domesticCurve，但currency为外币代码，如 "USD"

返回值：外汇远期合约的净现值（NPV）

示例：

pricingDate = "2025.08.18"
instrument = "{\"productType\": \"Forward\", \"forwardType\": \"FxForward\", \"version\": 0, \"expiry\": \"2025.12.16\", \"delivery\": \"2025.12.18\", \"currencyPair\": \"USDCNY\", \"direction\": \"Buy\", \"notional\": [\"USD\", 1000000], \"strike\": 7.1}"
spot = 7.1627
domesticCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"CNY\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.015113, 0.015402, 0.015660, 0.015574, 0.015556, 0.015655, 0.015703, 0.015934, 0.016040, 0.016020, 0.015928, 0.015842, 0.016068]}"
foreignCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"USD\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.043345, 0.043801, 0.043119, 0.043065, 0.042922, 0.042196, 0.041599, 0.040443, 0.040244, 0.039698, 0.037740, 0.036289, 0.035003]}"
'

def fx_forward_pricer_wrapper(instrument, pricingDate, spot, domesticCurve, foreignCurve) {
    // 转换参数
    pricingDateObj = date(pricingDate)
    instrumentObj = parseInstrument(fromStdJson(instrument))
    domesticCurveObj = parseMktData(fromStdJson(domesticCurve))
    foreignCurveObj = parseMktData(fromStdJson(foreignCurve))
    
    // 调用原始函数
    result = fxForwardPricer(instrumentObj, pricingDateObj, spot, domesticCurveObj, foreignCurveObj)
    
    return result
}

if (`fx_forward_pricer in (exec name from listMCPTools())) {
    updateMCPTool(`fx_forward_pricer, fx_forward_pricer_wrapper,
        `instrument`pricingDate`spot`domesticCurve`foreignCurve,
        ["STRING", "TEMPORAL", "DOUBLE", "STRING", "STRING"],
        description_fx_forward_pricer)
} else {
    addMCPTool(`fx_forward_pricer, fx_forward_pricer_wrapper,
        `instrument`pricingDate`spot`domesticCurve`foreignCurve,
        ["STRING", "TEMPORAL", "DOUBLE", "STRING", "STRING"],
        description_fx_forward_pricer)
}

publishMCPTools(`fx_forward_pricer)


// fxSwapPricer MCP 工具
description_fx_swap_pricer = '
计算外汇掉期的净现值。

参数说明：
- instrument: STRING，JSON格式的外汇掉期定义，包含以下字段：
  * productType: STRING，固定填 "Swap"
  * swapType: STRING，固定填 "FxSwap"
  * version: INT，版本号，默认值 0
  * currencyPair: STRING，货币对，如 "EURUSD"
  * direction: STRING，交易方向，可选值："Buy", "Sell"
  * notional: ARRAY，名义本金，格式为 [货币, 金额]，如 ["EUR", 1.0]
  * nearStrike: DOUBLE，近端执行汇率
  * nearExpiry: DATE，近端到期日
  * nearDelivery: DATE，近端交割日
  * farStrike: DOUBLE，远端执行汇率
  * farExpiry: DATE，远端到期日
  * farDelivery: DATE，远端交割日

- pricingDate: TEMPORAL，定价日期

- spot: DOUBLE，汇率即期价格

- domesticCurve: STRING，JSON格式的本币折现曲线定义，包含以下字段：
  * mktDataType: STRING，固定填 "Curve"
  * curveType: STRING，固定填 "IrYieldCurve"
  * referenceDate: TEMPORAL，参考日期
  * currency: STRING，本币货币代码，如 "USD"
  * dayCountConvention: STRING，日期计数惯例，如 "Actual365"
  * compounding: STRING，复利类型，如 "Continuous"
  * interpMethod: STRING，内插方法，如 "Linear"
  * extrapMethod: STRING，外插方法，如 "Flat"
  * dates: TEMPORAL[]，曲线节点日期
  * values: DOUBLE[]，曲线节点利率值

- foreignCurve: STRING，JSON格式的外币折现曲线定义，结构同domesticCurve，但currency为外币代码，如 "EUR"

返回值：外汇掉期的净现值

示例：

pricingDate = "2019.07.08"
spot = 1.121440
nearStrike = 1.345728
farStrike = 1.457872
instrument = "{\"productType\": \"Swap\", \"swapType\": \"FxSwap\", \"version\": 0, \"currencyPair\": \"EURUSD\", \"direction\": \"Buy\", \"notional\": [\"EUR\", 1.0], \"nearStrike\": 1.345728, \"nearExpiry\": \"2019.09.06\", \"nearDelivery\": \"2019.09.08\", \"farStrike\": 1.457872, \"farExpiry\": \"2020.01.04\", \"farDelivery\": \"2020.01.06\"}"
domesticCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2019.07.08\", \"currency\": \"USD\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"dates\":[\"2019.07.11\",\"2019.07.17\",\"2019.07.24\",\"2019.07.31\",\"2019.08.12\",\"2019.09.10\",\"2019.10.10\",\"2019.11.12\",\"2019.12.10\",\"2020.01.10\",\"2020.07.10\",\"2021.07.12\",\"2022.07.11\",\"2023.07.10\",\"2024.07.10\",\"2026.07.10\",\"2029.07.10\",\"2031.07.10\",\"2034.07.10\",\"2039.07.11\",\"2044.07.11\",\"2049.07.12\"], \"values\":[0.024433786134411,0.024225126571919,0.024203010643806,0.024252576792355,0.023348051909759,0.022593559840125,0.021891811294372,0.021291616688325,0.020886012824316,0.020409262542373,0.019005159354464,0.017073428214003,0.016410798532383,0.016203233730226,0.016255011191322,0.016851466518667,0.017957189552101,0.018610726199485,0.019340305980536,0.020001191737437,0.020201594379878,0.020216617011401]}"
foreignCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2019.07.08\", \"currency\": \"EUR\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"dates\":[\"2019.10.10\",\"2020.01.10\",\"2020.04.14\",\"2020.07.10\",\"2021.07.12\",\"2022.07.11\",\"2023.07.10\",\"2024.07.10\",\"2025.07.10\",\"2026.07.10\",\"2027.07.12\",\"2028.07.10\",\"2029.07.10\",\"2031.07.10\",\"2034.07.10\",\"2039.07.11\",\"2049.07.12\"], \"values\":[-0.007345102338368,-0.008654649379004,-0.008422501629097,-0.008738403997866,-0.008889601805667,-0.008605342810131,-0.00821441486039,-0.007748217572754,-0.00713503972541,-0.006488486697206,-0.005707543758268,-0.004938425925559,-0.004163226326896,-0.002690857963478,-0.000768483114767,0.001548680736784,0.003178263207137]}"
'

def fx_swap_pricer_wrapper(instrument, pricingDate, spot, domesticCurve, foreignCurve) {
    // 转换参数
    ins = parseInstrument(fromStdJson(instrument))
    pricingDateObj = date(pricingDate)
    domesticCurveObj = parseMktData(fromStdJson(domesticCurve))
    foreignCurveObj = parseMktData(fromStdJson(foreignCurve))
    
    // 调用原始函数
    result = fxSwapPricer(ins, pricingDateObj, spot, domesticCurveObj, foreignCurveObj)
    
    return result
}

if (`fx_swap_pricer in (exec name from listMCPTools())) {
    updateMCPTool(`fx_swap_pricer, fx_swap_pricer_wrapper,
        `instrument`pricingDate`spot`domesticCurve`foreignCurve,
        ["STRING", "TEMPORAL", "DOUBLE", "STRING", "STRING"],
        description_fx_swap_pricer)
} else {
    addMCPTool(`fx_swap_pricer, fx_swap_pricer_wrapper,
        `instrument`pricingDate`spot`domesticCurve`foreignCurve,
        ["STRING", "TEMPORAL", "DOUBLE", "STRING", "STRING"],
        description_fx_swap_pricer)
}

publishMCPTools(`fx_swap_pricer)



// fxEuropeanOptionPricer MCP 工具（带波动率曲面构建）
description_fx_european_option_pricer = '
对外汇欧式期权进行定价，返回期权的净现值（NPV）。该工具会在内部构建所需的波动率曲面。

参数说明：
- instrument: STRING，JSON格式的外汇欧式期权定义
- pricingDate: TEMPORAL，定价日期
- spot: DOUBLE，标的汇率的即期价格
- domesticCurve: STRING，JSON格式的本币折现曲线定义
- foreignCurve: STRING，JSON格式的外币折现曲线定义
- currencyPair: STRING，货币对，如 "USDCNY"
- quoteNames: STRING[]，波动率报价名称，如 ["ATM", "D25_RR", "D25_BF", "D10_RR", "D10_BF"]
- quoteTerms: STRING[]，波动率报价期限，如 ["1d", "1w", "2w", "3w", "1M", "2M", "3M", "6M", "9M", "1y", "18M", "2y", "3y"]
- quotes: DOUBLE[]，波动率报价数据（按行优先排列）

返回值：期权的净现值（NPV）

示例：

// instrument 参数
instrument = "{\"productType\": \"Option\", \"optionType\": \"EuropeanOption\", \"assetType\": \"FxEuropeanOption\", \"version\": 0, \"notional\": [\"USD\", 1000000], \"strike\": 7.2, \"maturity\": \"2025.10.28\", \"payoffType\": \"Call\", \"dayCountConvention\": \"Actual365\", \"underlying\": \"USDCNY\"}"

// pricingDate 参数
pricingDate = "2025.08.18"

// spot 参数
spot = 7.1627

// domesticCurve 参数
domesticCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"CNY\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.015113, 0.015402, 0.015660, 0.015574, 0.015556, 0.015655, 0.015703, 0.015934, 0.016040, 0.016020, 0.015928, 0.015842, 0.016068]}"

// foreignCurve 参数
foreignCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"USD\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.043345, 0.043801, 0.043119, 0.043065, 0.042922, 0.042196, 0.041599, 0.040443, 0.040244, 0.039698, 0.037740, 0.036289, 0.035003]}"

// currencyPair 参数
currencyPair = "USDCNY"

// quoteNames 参数
quoteNames = ["ATM", "D25_RR", "D25_BF", "D10_RR", "D10_BF"]

// quoteTerms 参数
quoteTerms = ["1d", "1w", "2w", "3w", "1M", "2M", "3M", "6M", "9M", "1y", "18M", "2y", "3y"]

// quotes 参数
quotes = [0.030000, -0.007500, 0.003500, -0.010000, 0.005500, 0.020833, -0.004500, 0.002000, -0.006000, 0.003800, 0.022000, -0.003500, 0.002000, -0.004500, 0.004100, 0.022350, -0.003500, 0.002000, -0.004500, 0.004150, 0.024178, -0.003000, 0.002200, -0.004750, 0.005500, 0.027484, -0.002650, 0.002220, -0.004000, 0.005650, 0.030479, -0.002500, 0.002400, -0.003500, 0.005750, 0.035752, -0.000500, 0.002750, 0.000000, 0.006950, 0.038108, 0.001000, 0.002800, 0.003000, 0.007550, 0.039492, 0.002250, 0.002950, 0.005000, 0.007550, 0.040500, 0.004000, 0.003100, 0.007000, 0.007850, 0.041750, 0.005250, 0.003350, 0.008000, 0.008400, 0.044750, 0.006250, 0.003400, 0.009000, 0.008550]
'

def fx_european_option_pricer_wrapper(instrument, pricingDate, spot, domesticCurve, foreignCurve, currencyPair, quoteNames, quoteTerms, quotes) {
    // 转换参数
    refDate = date(pricingDate)
    instrumentObj = parseInstrument(fromStdJson(instrument))
    domesticCurveObj = parseMktData(fromStdJson(domesticCurve))
    foreignCurveObj = parseMktData(fromStdJson(foreignCurve))
    
    // 将quotes转换为矩阵格式
    quotesMatrix = reshape(quotes, size(quoteTerms):size(quoteNames))
    
    // 构建波动率曲面
    volSurf = fxVolatilitySurfaceBuilder(refDate, currencyPair, quoteNames, quoteTerms, quotesMatrix, spot, domesticCurveObj, foreignCurveObj)
    
    // 调用原始函数
    result = fxEuropeanOptionPricer(instrumentObj, refDate, spot, domesticCurveObj, foreignCurveObj, volSurf)
    
    return result
}

if (`fx_european_option_pricer in (exec name from listMCPTools())) {
    updateMCPTool(`fx_european_option_pricer, fx_european_option_pricer_wrapper,
        `instrument`pricingDate`spot`domesticCurve`foreignCurve`currencyPair`quoteNames`quoteTerms`quotes,
        ["STRING", "TEMPORAL", "DOUBLE", "STRING", "STRING", "STRING", "STRING[]", "STRING[]", "DOUBLE[]"],
        description_fx_european_option_pricer)
} else {
    addMCPTool(`fx_european_option_pricer, fx_european_option_pricer_wrapper,
        `instrument`pricingDate`spot`domesticCurve`foreignCurve`currencyPair`quoteNames`quoteTerms`quotes,
        ["STRING", "TEMPORAL", "DOUBLE", "STRING", "STRING", "STRING", "STRING[]", "STRING[]", "DOUBLE[]"],
        description_fx_european_option_pricer)
}

publishMCPTools(`fx_european_option_pricer)


// parseMktData MCP 工具
description_parse_mkt_data = '
将输入的字典或JSON字符串解析为MKTDATA类型对象，支持即期价格、期限结构曲线和波动率曲面等市场数据类型。

在调用其他工具时，可以使用此工具确认市场数据字典MKTDATA的格式准确性。

参数说明：
- mktDataDict: STRING，JSON格式的市场数据字典字符串

支持的市场数据类型：

1. FxSpot（外汇即期汇率）- 必填字段：
   - mktDataType: "Spot"
   - referenceDate: 参考日期
   - spotType: "FxSpot"
   - value: 即期价格
   - unit: 货币对，可选值："EURUSD", "USDCNY", "EURCNY", "GBPCNY", "JPYCNY", "HKDCNY"
   - 可选字段：version（默认0）, spotDate（即期交割日）

2. IrYieldCurve（利率收益率曲线）- 必填字段：
   - mktDataType: "Curve"
   - curveType: "IrYieldCurve"
   - referenceDate: 参考日期
   - dayCountConvention: 日期计数惯例，可选值："Actual360", "Actual365", "ActualActualISMA", "ActualActualISDA"
   - interpMethod: 内插方法，可选值："Linear", "CubicSpline", "CubicHermiteSpline"
   - extrapMethod: 外插方法，可选值："Flat", "Linear"
   - dates: 数据点日期数组
   - values: 数据点值数组
   - currency: 货币，可选值："CNY", "USD", "EUR", "GBP", "JPY", "HKD"
   - compounding: 复利类型，可选值："Simple", "Compounded", "Continuous"
   - 可选字段：version（默认0）, curveName, settlement, frequency, curveModel, curveParams

3. AssetPriceCurve（资产价格曲线）- 必填字段：
   - mktDataType: "Curve"
   - curveType: "AssetPriceCurve"
   - referenceDate: 参考日期
   - dates: 数据点日期数组
   - values: 数据点值数组
   - 可选字段：version（默认0）, curveName

4. FxVolatilitySurface（外汇波动率曲面）- 必填字段：
   - mktDataType: "Surface"
   - surfaceType: "FxVolatilitySurface"
   - referenceDate: 参考日期
   - smileMethod: 波动率微笑方法，可选值："Linear", "CubicSpline", "SVI", "SABR"
   - volSmiles: 波动率微笑数组
   - termDates: 期限日期数组
   - currencyPair: 货币对
   - 可选字段：version（默认0）, surfaceName

返回值：返回解析后的MKTDATA类型对象的JSON格式

示例：

示例一：解析外汇即期汇率
mktDataDict = "{\"mktDataType\": \"Spot\", \"referenceDate\": \"2025.08.18\", \"version\": 0, \"spotDate\": \"2025.08.20\", \"spotType\": \"FxSpot\", \"value\": 7.2659, \"unit\": \"USDCNY\"}"

示例二：解析利率收益率曲线
mktDataDict = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"version\": 0, \"referenceDate\": \"2025.07.01\", \"currency\": \"CNY\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"dates\":[\"2025.07.07\",\"2025.07.10\",\"2025.07.17\",\"2025.07.24\",\"2025.08.04\",\"2025.09.03\",\"2025.10.09\",\"2026.01.05\",\"2026.04.03\",\"2026.07.03\",\"2027.01.04\",\"2027.07.05\",\"2028.07.03\"], \"values\":[0.015785,0.015931,0.016183,0.016381,0.016493,0.016503,0.016478,0.016234,0.016321,0.016378,0.015508,0.015185,0.014901], \"settlement\": \"2025.07.03\"}"

示例三：解析资产价格曲线
mktDataDict = "{\"mktDataType\": \"Curve\", \"curveType\": \"AssetPriceCurve\", \"version\": 0, \"referenceDate\": \"2024.06.28\", \"curveName\": \"PRICE_SHIBOR_3M\", \"dates\": [\"2024.06.21\", \"2024.06.24\", \"2024.06.25\", \"2024.06.26\", \"2024.06.27\"], \"values\": [0.01923, 0.01922, 0.01921, 0.01919, 0.01918]}"

示例四：解析外汇波动率曲面
mktDataDict = "{\"surfaceName\": \"USDCNY\", \"mktDataType\": \"Surface\", \"surfaceType\": \"FxVolatilitySurface\", \"version\": 0, \"referenceDate\": \"2025.08.18\", \"smileMethod\": \"Linear\", \"termDates\": [\"2025.08.21\", \"2026.08.20\"], \"volSmiles\":[{\"strikes\": [6.5,7,7.5],\"vols\": [0.1,0.1,0.1]},{\"strikes\": [6.5,7,7.5],\"vols\": [0.1,0.1,0.1]}], \"currencyPair\": \"USDCNY\"}"
'

def parse_mkt_data_wrapper(mktDataDict) {
    // 解析JSON字符串为字典
    dataDict = fromStdJson(mktDataDict)
    
    // 调用原始函数
    result = parseMktData(dataDict)
    
    // 提取市场数据并转换为JSON
    extractedData = extractMktData(result)
    return toStdJson(extractedData)
}

if (`parse_mkt_data in (exec name from listMCPTools())) {
    updateMCPTool(`parse_mkt_data, parse_mkt_data_wrapper,
        ["mktDataDict"],
        ["STRING"],
        description_parse_mkt_data)
} else {
    addMCPTool(`parse_mkt_data, parse_mkt_data_wrapper,
        ["mktDataDict"],
        ["STRING"],
        description_parse_mkt_data)
}

publishMCPTools(`parse_mkt_data)


// parseInstrument MCP 工具
description_parse_instrument = '
将输入的金融工具产品描述转换成一个 INSTRUMENT 类型对象，用于后续建模和定价。

在调用其他工具时，可以使用此工具确认金融工具字典INSTRUMENT的格式准确性。

参数说明：
- obj: STRING，JSON格式的金融工具描述字典

支持的金融工具类型：
1. 贴现债（DiscountBond）
2. 零息债（ZeroCouponBond）
3. 固定利率债（FixedRateBond）
4. 国债期货（BondFutures）
5. 存款（Deposit）
6. 利率互换（IrFixedFloatingSwap）
7. 外汇远期（FxForward）
8. 外汇掉期（FxSwap）
9. 外汇欧式期权（FxEuropeanOption）

返回值：返回解析后的 INSTRUMENT 类型对象的JSON格式

示例：

示例一：贴现债
obj = "{\"productType\": \"Cash\", \"assetType\": \"Bond\", \"bondType\": \"DiscountBond\", \"version\": 0, \"instrumentId\": \"259924.IB\", \"start\": \"2025.04.17\", \"maturity\": \"2025.07.17\", \"issuePrice\": 99.664, \"dayCountConvention\": \"ActualActualISDA\"}"

示例二：零息债
obj = "{\"productType\": \"Cash\", \"assetType\": \"Bond\", \"bondType\": \"ZeroCouponBond\", \"version\": 0, \"instrumentId\": \"250401.IB\", \"start\": \"2025.01.09\", \"maturity\": \"2026.02.05\", \"coupon\": 0.0119, \"frequency\": \"Annual\", \"dayCountConvention\": \"ActualActualISDA\"}"

示例三：固定利率债
obj = "{\"productType\": \"Cash\", \"assetType\": \"Bond\", \"bondType\": \"FixedRateBond\", \"version\": 0, \"instrumentId\": \"240021.IB\", \"start\": \"2024.10.25\", \"maturity\": \"2025.10.25\", \"issuePrice\": 100, \"coupon\": 0.0133, \"frequency\": \"Annual\", \"dayCountConvention\": \"ActualActualISDA\"}"

示例四：国债期货
obj = "{\"productType\": \"Futures\", \"futuresType\": \"BondFutures\", \"version\": 0, \"instrumentId\": \"T2509\", \"nominal\": 100.0, \"maturity\": \"2022.09.09\", \"settlement\": \"2022.09.11\", \"underlying\": {\"productType\": \"Cash\", \"assetType\": \"Bond\", \"bondType\": \"FixedRateBond\", \"version\": 0, \"instrumentId\": \"220010.IB\", \"start\": \"2020.12.25\", \"maturity\": \"2031.12.25\", \"issuePrice\": 100.0, \"coupon\": 0.0149, \"frequency\": \"Annual\", \"dayCountConvention\": \"ActualActualISDA\"}, \"nominalCouponRate\": 0.03}"

示例五：存款
obj = "{\"productType\": \"Cash\", \"assetType\": \"Deposit\", \"version\": 0, \"start\": \"2025.05.15\", \"maturity\": \"2025.08.15\", \"rate\": 0.02, \"dayCountConvention\": \"Actual360\", \"notional\": [\"CNY\", 1000000], \"payReceive\": \"Receive\"}"

示例六：利率互换
obj = "{\"productType\": \"Swap\", \"swapType\": \"IrSwap\", \"irSwapType\": \"IrFixedFloatingSwap\", \"version\": 0, \"start\": \"2021.05.15\", \"maturity\": \"2023.05.15\", \"frequency\": \"Quarterly\", \"fixedRate\": 0.02, \"calendar\": \"CFET\", \"fixedDayCountConvention\": \"Actual365\", \"floatingDayCountConvention\": \"Actual360\", \"payReceive\": \"Pay\", \"iborIndex\": \"SHIBOR_3M\", \"spread\": 0.0005, \"notional\": [\"CNY\", 100000000]}"

示例七：外汇远期
obj = "{\"productType\": \"Forward\", \"forwardType\": \"FxForward\", \"version\": 0, \"expiry\": \"2025.09.24\", \"delivery\": \"2025.09.26\", \"currencyPair\": \"USDCNY\", \"direction\": \"Buy\", \"notional\": [\"USD\", 100000000], \"strike\": 7.2}"

示例八：外汇掉期
obj = "{\"productType\": \"Swap\", \"swapType\": \"FxSwap\", \"version\": 0, \"currencyPair\": \"EURUSD\", \"direction\": \"Buy\", \"notional\": [\"EUR\", 1000000], \"nearStrike\": 1.1, \"nearExpiry\": \"2025.12.08\", \"nearDelivery\": \"2025.12.10\", \"farStrike\": 1.2, \"farExpiry\": \"2026.06.08\", \"farDelivery\": \"2026.06.10\"}"

示例九：外汇欧式期权
obj = "{\"productType\": \"Option\", \"optionType\": \"EuropeanOption\", \"assetType\": \"FxEuropeanOption\", \"version\": 0, \"notional\": [\"EUR\", 1000000.0], \"strike\": 1.2, \"maturity\": \"2025.10.08\", \"payoffType\": \"Call\", \"dayCountConvention\": \"Actual365\", \"underlying\": \"EURUSD\"}"
'

def parse_instrument_wrapper(obj) {
    objDict = fromStdJson(obj)
    instrument = parseInstrument(objDict)
    result = extractInstrument(instrument)
    return toStdJson(result)
}

if (`parse_instrument in (exec name from listMCPTools())) {
    updateMCPTool(`parse_instrument, parse_instrument_wrapper,
        ["obj"],
        ["STRING"],
        description_parse_instrument)
} else {
    addMCPTool(`parse_instrument, parse_instrument_wrapper,
        ["obj"],
        ["STRING"],
        description_parse_instrument)
}


publishMCPTools(`parse_instrument)



// curvePredict MCP 工具
description_curve_predict = '
在给定的曲线上，预测指定点位的曲线值。目前仅支持零息利率曲线。

参数说明：
- curve: STRING，JSON格式的曲线定义（IrYieldCurve类型），包含以下键：
  * mktDataType: STRING，固定填 "Curve"
  * curveType: STRING，固定填 "IrYieldCurve"
  * referenceDate: TEMPORAL，参考日期
  * currency: STRING，货币，可选值："CNY", "USD", "EUR", "GBP", "JPY", "HKD"
  * dayCountConvention: STRING，日期计数惯例，如 "ActualActualISDA", "Actual365", "Actual360"
  * compounding: STRING，复利类型，如 "Continuous", "Compounded", "Simple"
  * interpMethod: STRING，内插方法，如 "Linear", "CubicSpline"
  * extrapMethod: STRING，外插方法，如 "Flat", "Linear"
  * frequency: STRING，计息频率，如 "Annual", "Semiannual"
  * dates: TEMPORAL[]，曲线节点日期
  * values: DOUBLE[]，曲线节点值
- dt: TEMPORAL[]，预测点位的日期列表，支持单个日期或多个日期

返回值：预测的曲线值（DOUBLE类型标量或向量）

示例：

示例一：预测单个日期的曲线值
curve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"CNY\", \"dayCountConvention\": \"ActualActualISDA\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.015113, 0.015402, 0.015660, 0.015574, 0.015556, 0.015655, 0.015703, 0.015934, 0.016040, 0.016020, 0.015928, 0.015842, 0.016068]}"
dt = ["2025.10.18"]

示例二：预测多个日期的曲线值
curve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"CNY\", \"dayCountConvention\": \"ActualActualISDA\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.015113, 0.015402, 0.015660, 0.015574, 0.015556, 0.015655, 0.015703, 0.015934, 0.016040, 0.016020, 0.015928, 0.015842, 0.016068]}"
dt = ["2025.10.18", "2026.10.18"]
'

def curve_predict_wrapper(curve, dt) {
    // 解析曲线
    curveObj = parseMktData(fromStdJson(curve))
    
    // 转换日期参数 - 支持单个日期或多个日期
    dtDates = date(dt)
    
    // 调用原始函数
    result = curvePredict(curveObj, dtDates)
    
    return toStdJson(result)
}

if (`curve_predict in (exec name from listMCPTools())) {
    updateMCPTool(`curve_predict, curve_predict_wrapper,
        `curve`dt,
        ["STRING", "TEMPORAL[]"],
        description_curve_predict)
} else {
    addMCPTool(`curve_predict, curve_predict_wrapper,
        `curve`dt,
        ["STRING", "TEMPORAL[]"],
        description_curve_predict)
}

publishMCPTools(`curve_predict)


// optionVolPredict MCP 工具
description_option_vol_predict = '
给定点位的时间和行权价，从构建的波动率曲面上预测点位对应的波动率。

参数说明：
- referenceDate: TEMPORAL，波动率曲面的参考日期，如 "2025.08.18"
- currencyPair: STRING，货币对，如 "USDCNY"
- quoteNames: STRING[]，报价名称列表，如 ["ATM", "D25_RR", "D25_BF", "D10_RR", "D10_BF"]
- quoteTerms: STRING[]，报价期限列表，如 ["1d", "1w", "2w", "3w", "1M", "2M", "3M", "6M", "9M", "1y", "18M", "2y", "3y"]
- quotes: DOUBLE[]，市场报价数据（按行优先排列），如波动率报价矩阵
- spot: DOUBLE，即期汇率，如 7.1627
- domesticCurve: STRING，JSON格式的本币贴现曲线定义
- foreignCurve: STRING，JSON格式的外币贴现曲线定义
- model: STRING，波动率曲面模型，如 "SVI"
- dt: TEMPORAL[]，日期标量或向量，表示预测点位的具体日期
- strike: DOUBLE[]，执行价格标量或向量，表示执行价格

返回值：DOUBLE类型矩阵，形状为size(dt) * size(strike)。行对应输入的dt（到期时间/日期），列对应输入的strike（执行价）

示例：

示例一：单个日期单个执行价预测
referenceDate = "2025.08.18"
currencyPair = "USDCNY"
quoteNames = ["ATM", "D25_RR", "D25_BF", "D10_RR", "D10_BF"]
quoteTerms = ["1d", "1w", "2w", "3w", "1M", "2M", "3M", "6M", "9M", "1y", "18M", "2y", "3y"]
quotes = [0.030000, -0.007500, 0.003500, -0.010000, 0.005500, 0.020833, -0.004500, 0.002000, -0.006000, 0.003800, 0.022000, -0.003500, 0.002000, -0.004500, 0.004100, 0.022350, -0.003500, 0.002000, -0.004500, 0.004150, 0.024178, -0.003000, 0.002200, -0.004750, 0.005500, 0.027484, -0.002650, 0.002220, -0.004000, 0.005650, 0.030479, -0.002500, 0.002400, -0.003500, 0.005750, 0.035752, -0.000500, 0.002750, 0.000000, 0.006950, 0.038108, 0.001000, 0.002800, 0.003000, 0.007550, 0.039492, 0.002250, 0.002950, 0.005000, 0.007550, 0.040500, 0.004000, 0.003100, 0.007000, 0.007850, 0.041750, 0.005250, 0.003350, 0.008000, 0.008400, 0.044750, 0.006250, 0.003400, 0.009000, 0.008550]
spot = 7.1627
domesticCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"CNY\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.015113, 0.015402, 0.015660, 0.015574, 0.015556, 0.015655, 0.015703, 0.015934, 0.016040, 0.016020, 0.015928, 0.015842, 0.016068]}"
foreignCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"USD\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.043345, 0.043801, 0.043119, 0.043065, 0.042922, 0.042196, 0.041599, 0.040443, 0.040244, 0.039698, 0.037740, 0.036289, 0.035003]}"
model = "SVI"
dt = ["2025.10.18"]
strike = [7.0]

示例二：单个日期多个执行价预测
referenceDate = "2025.08.18"
currencyPair = "USDCNY"
quoteNames = ["ATM", "D25_RR", "D25_BF", "D10_RR", "D10_BF"]
quoteTerms = ["1d", "1w", "2w", "3w", "1M", "2M", "3M", "6M", "9M", "1y", "18M", "2y", "3y"]
quotes = [0.030000, -0.007500, 0.003500, -0.010000, 0.005500, 0.020833, -0.004500, 0.002000, -0.006000, 0.003800, 0.022000, -0.003500, 0.002000, -0.004500, 0.004100, 0.022350, -0.003500, 0.002000, -0.004500, 0.004150, 0.024178, -0.003000, 0.002200, -0.004750, 0.005500, 0.027484, -0.002650, 0.002220, -0.004000, 0.005650, 0.030479, -0.002500, 0.002400, -0.003500, 0.005750, 0.035752, -0.000500, 0.002750, 0.000000, 0.006950, 0.038108, 0.001000, 0.002800, 0.003000, 0.007550, 0.039492, 0.002250, 0.002950, 0.005000, 0.007550, 0.040500, 0.004000, 0.003100, 0.007000, 0.007850, 0.041750, 0.005250, 0.003350, 0.008000, 0.008400, 0.044750, 0.006250, 0.003400, 0.009000, 0.008550]
spot = 7.1627
domesticCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"CNY\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.015113, 0.015402, 0.015660, 0.015574, 0.015556, 0.015655, 0.015703, 0.015934, 0.016040, 0.016020, 0.015928, 0.015842, 0.016068]}"
foreignCurve = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"USD\", \"dayCountConvention\": \"Actual365\", \"compounding\": \"Continuous\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.08.21\", \"2025.08.27\", \"2025.09.03\", \"2025.09.10\", \"2025.09.22\", \"2025.10.20\", \"2025.11.20\", \"2026.02.24\", \"2026.05.20\", \"2026.08.20\", \"2027.02.22\", \"2027.08.20\", \"2028.08.21\"], \"values\": [0.043345, 0.043801, 0.043119, 0.043065, 0.042922, 0.042196, 0.041599, 0.040443, 0.040244, 0.039698, 0.037740, 0.036289, 0.035003]}"
model = "SVI"
dt = ["2025.10.18"]
strike = [7.1, 7.2]

示例三：多个日期单个执行价预测
referenceDate = "2025.08.18"
currencyPair = "USDCNY"
