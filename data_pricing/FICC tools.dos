def option_vol_predict_wrapper(referenceDate, currencyPair, quoteNames, quoteTerms, quotes, spot, domesticCurve, foreignCurve, model, dt, strike) {
    // 转换参数
    refDate = date(referenceDate)
    dtDates = date(dt)
    quotesT = reshape(quotes, size(quoteNames):size(quoteTerms)).transpose()

    // 解析曲线
    domesticCurveObj = parseMktData(fromStdJson(domesticCurve))
    foreignCurveObj = parseMktData(fromStdJson(foreignCurve))
    
    // 构建波动率曲面
    surf = fxVolatilitySurfaceBuilder(refDate, currencyPair, quoteNames, quoteTerms, quotesT, spot, domesticCurveObj, foreignCurveObj, model=model)
    
    // 预测波动率
    result = optionVolPredict(surf, dtDates, strike)
    
    return toStdJson(result)
}

if (`option_vol_predict in (exec name from listMCPTools())) {
    updateMCPTool(`option_vol_predict, option_vol_predict_wrapper,
        `referenceDate`currencyPair`quoteNames`quoteTerms`quotes`spot`domesticCurve`foreignCurve`model`dt`strike,
        ["TEMPORAL", "STRING", "STRING[]", "STRING[]", "DOUBLE[]", "DOUBLE", "STRING", "STRING", "STRING", "TEMPORAL[]", "DOUBLE[]"],
        description_option_vol_predict)
} else {
    addMCPTool(`option_vol_predict, option_vol_predict_wrapper,
        `referenceDate`currencyPair`quoteNames`quoteTerms`quotes`spot`domesticCurve`foreignCurve`model`dt`strike,
        ["TEMPORAL", "STRING", "STRING[]", "STRING[]", "DOUBLE[]", "DOUBLE", "STRING", "STRING", "STRING", "TEMPORAL[]", "DOUBLE[]"],
        description_option_vol_predict)
}

publishMCPTools(`option_vol_predict)

















