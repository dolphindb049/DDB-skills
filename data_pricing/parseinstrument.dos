description_delete_instrument = '
根据债券代码删除instrument表中的记录。

参数说明：
- instrumentId: STRING，要删除的债券代码

返回值：
返回删除操作结果

示例：
instrumentId = "250015.IB"
'

def delete_instrument_wrapper(instrumentId) {
    try {
        // 先查询要删除的记录
        checkSql = 'select instrumentId, instrumentName from loadTable("dfs://ficc_data2", "instrument") where instrumentId = "' + instrumentId + '"'
        checkResult = parseExpr(checkSql).eval()
        
        if (size(checkResult) == 0) {
            return "未找到债券代码为 " + instrumentId + " 的记录"
        }
        
        // 执行删除
        tb = loadTable("dfs://ficc_data2", "instrument")  
  
        // 使用sqlDelete函数  
        sqlDelete(tb, <instrumentId = instrumentId>).eval()
        
        return "成功删除 " + string(size(checkResult)) + " 条记录，债券代码: " + instrumentId
        
    } catch(ex) {
        return "删除失败: " + string(ex)
    }
}

// delete_curve MCP 工具
description_delete_curve = '
根据参考日期和曲线名称删除curve表中的记录。

参数说明：
- referenceDate: TEMPORAL，参考日期
- curveName: STRING，曲线名称

返回值：
返回删除操作结果

示例：
referenceDate = "2025.08.18"
curveName = "CNY_TREASURY_BOND"
'

def delete_curve_wrapper(referenceDate, curveName) {
    try {
        // 先查询要删除的记录
        checkSql = 'select referenceDate, curveName from loadTable("dfs://ficc_data2", "curve") where referenceDate = ' + string(date(referenceDate)) + ' and curveName = "' + curveName + '"'
        checkResult = parseExpr(checkSql).eval()
        
        if (size(checkResult) == 0) {
            return "未找到参考日期为 " + string(date(referenceDate)) + "，曲线名称为 " + curveName + " 的记录"
        }
        
        // 执行删除
        tb = loadTable("dfs://ficc_data2", "curve")  
  
        // 使用sqlDelete函数  
        sqlDelete(tb, <referenceDate = date(referenceDate) and curveName = curveName>).eval()
                
        return "成功删除 " + string(size(checkResult)) + " 条记录，参考日期: " + string(date(referenceDate)) + "，曲线名称: " + curveName
        
    } catch(ex) {
        return "删除失败: " + string(ex)
    }
}

if (`delete_instrument in (exec name from listMCPTools())) {
    updateMCPTool(`delete_instrument, delete_instrument_wrapper,
        [`instrumentId],
        ["STRING"],
        description_delete_instrument)
} else {
    addMCPTool(`delete_instrument, delete_instrument_wrapper,
        [`instrumentId],
        ["STRING"],
        description_delete_instrument)
}

if (`delete_curve in (exec name from listMCPTools())) {
    updateMCPTool(`delete_curve, delete_curve_wrapper,
        `referenceDate`curveName,
        ["TEMPORAL", "STRING"],
        description_delete_curve)
} else {
    addMCPTool(`delete_curve, delete_curve_wrapper,
        `referenceDate`curveName,
        ["TEMPORAL", "STRING"],
        description_delete_curve)
}

// 发布工具
publishMCPTools(`delete_instrument`delete_curve)


// query_instrument MCP 工具
description_query_instrument = '
查询数据库中现有的债券记录信息。

参数说明：
- instrumentWhere: STRING，筛选instrument表的WHERE条件，如"instrumentId = \"220019.IB\""或"instrumentName like \"%国债%\""

债券筛选可用列：
- instrumentId（优先）：债券代码
- instrumentName：债券名称
- assetType：资产类型
- listingDate：上市日期
- market：市场代码

返回值：
返回匹配的债券记录详细信息，包括基本信息和解析后的债券结构

示例：
instrumentWhere = "instrumentId = \"220019.IB\""
或者：
instrumentWhere = "instrumentName like \"%国债%\" and market = \"IB\""
或者：
instrumentWhere = "assetType = \"Bond\" limit 10"
'

def query_instrument_wrapper(instrumentWhere) {
    try {
        // 从数据库查询债券基本信息
        instrumentSql = 'select instrumentId, instrumentName, assetType, listingDate, market from loadTable("dfs://ficc_data2", "instrument") where ' + instrumentWhere
        instrumentResult = parseExpr(instrumentSql).eval()
        
        if (size(instrumentResult) == 0) {
            return "未找到匹配的债券记录，筛选条件: " + instrumentWhere
        }
        
        // 获取完整的instrument详细数据
        fullInstrumentSql = 'select instrumentId, instrumentName, assetType, listingDate, market, instrument from loadTable("dfs://ficc_data2", "instrument") where ' + instrumentWhere
        fullInstrumentData = parseExpr(fullInstrumentSql).eval()

        keyInstrumentData = select instrumentId, instrumentName, assetType, listingDate, market from fullInstrumentData limit 10

        // 仅返回第一条记录的详细信息
        instrumentObj = fullInstrumentData.instrument[0]
        instrumentDict = extractInstrument(instrumentObj)
        // 构建返回结果

        result = dict(`查询结果数量`前10条查询结果`第一条债券详细记录, [size(fullInstrumentData),keyInstrumentData, instrumentDict])
        return toStdJson(result)
        
    } catch(ex) {
        return "查询失败: " + string(ex)
    }
}

// query_curve MCP 工具
description_query_curve = '
查询数据库中现有的曲线记录信息。

参数说明：
- curveWhere: STRING，筛选curve表的WHERE条件，如"curveName = \"CNY_TREASURY_BOND\""或"referenceDate = 2025.08.01"

曲线筛选可用列：
- referenceDate：参考日期（不用引号）
- curveName：曲线名称
- curveType：曲线类型

返回值：
返回匹配的曲线记录详细信息，包括基本信息和解析后的曲线结构

示例：
curveWhere = "curveName = \"CNY_TREASURY_BOND\" and referenceDate = 2025.08.01"
或者：
curveWhere = "referenceDate = 2025.08.01"
或者：
curveWhere = "curveName like \"%TREASURY%\" and referenceDate >= 2025.08.01 limit 5"
'

def query_curve_wrapper(curveWhere) {
    try {
        // 从数据库查询曲线基本信息
        curveSql = 'select referenceDate, curveName, curveType from loadTable("dfs://ficc_data2", "curve") where ' + curveWhere
        curveResult = parseExpr(curveSql).eval()
        
        if (size(curveResult) == 0) {
            return "未找到匹配的曲线记录，筛选条件: " + curveWhere
        }
        
        // 获取完整的curve详细数据
        fullCurveSql = 'select referenceDate, curveName, curveType, marketData from loadTable("dfs://ficc_data2", "curve") where ' + curveWhere
        fullCurveData = parseExpr(fullCurveSql).eval()
        
        keyCurveData = select referenceDate, curveName, curveType from fullCurveData limit 10

        // 仅返回第一条记录的详细信息
        marketDataObj = fullCurveData.marketData[0]
        marketDataDict = extractMktData(marketDataObj)
                
        result = dict(`查询结果数量`前10条查询结果`第一条曲线详细记录, [size(fullCurveData),keyCurveData, marketDataDict])
        return toStdJson(result)
        
    } catch(ex) {
        return "查询失败: " + string(ex)
    }
}

// 注册MCP工具
if (`query_instrument in (exec name from listMCPTools())) {
    updateMCPTool(`query_instrument, query_instrument_wrapper,
        [`instrumentWhere],
        ["STRING"],
        description_query_instrument)
} else {
    addMCPTool(`query_instrument, query_instrument_wrapper,
        [`instrumentWhere],
        ["STRING"],
        description_query_instrument)
}

if (`query_curve in (exec name from listMCPTools())) {
    updateMCPTool(`query_curve, query_curve_wrapper,
        [`curveWhere],
        ["STRING"],
        description_query_curve)
} else {
    addMCPTool(`query_curve, query_curve_wrapper,
        [`curveWhere],
        ["STRING"],
        description_query_curve)
}

// 发布新工具
publishMCPTools(`query_instrument`query_curve)


