

// save_instrument MCP 工具（简化版）
description_save_instrument_new = '
用于将债券信息解析并存储到数据库的instrument表中。

参数说明：
- bond: STRING，JSON格式的债券定义，包含以下字段：
  * productType: STRING，固定填 "Cash"
  * assetType: STRING，固定填 "Bond"
  * bondType: STRING，债券类型，可选值："DiscountBond", "ZeroCouponBond", "FixedRateBond"
  * version: INT，版本号，默认值 0
  * nominal: DOUBLE，名义金额，默认值 100
  * instrumentId: STRING，债券代码，如 "259926.IB"
  * start: DATE，起息日
  * maturity: DATE，到期日
  * dayCountConvention: STRING，日期计数惯例，可选 "ActualActualISDA", "ActualActualISMA", "Actual365", "Actual360"
  * issuePrice: DOUBLE，发行价格（贴现债必填）
  * coupon: DOUBLE，票面利率（固定利率债和零息债必填）
  * frequency: STRING，付息频率（固定利率债和零息债必填）
  * currency: STRING，货币，默认为 "CNY"
  * cashFlow: TABLE，债券现金流表（可选）
  * discountCurve: STRING，定价时参考的贴现曲线名称（可选，与subType必选其一）
  * spreadCurve: STRING，定价时参考的利差曲线名称（可选）
  * subType: STRING，债券子类型（可选，与discountCurve必选其一），可选值：
    - "TREASURY_BOND"：国债
    - "CENTRAL_BANK_BILL"：央行票据
    - "CDB_BOND"：政策性金融债（国开）
    - "EIBC_BOND"：政策性金融债（进出口行）
    - "ADBC_BOND"：政策性金融债（农发行）
    - "MTN"：中期票据
    - "CORP_BOND"：企业债
    - "UNSECURED_CORP_BOND"：无担保企业债
    - "SHORT_FIN_BOND"：短期融资券
    - "NCD"：同业存单
    - "LOC_GOV_BOND"：地方政府债
    - "COMM_BANK_FIN_BOND"：商业银行普通金融债
    - "BANK_SUB_CAP_BOND"：商业银行二级资本债
    - "ABS"：资产支持证券
    - "PPN"：非公开发行债
  * creditRating: STRING，信用等级类型（可选），可选值："B", "BB", "BBB", "BBB+", "A-", "A", "A+", "AA-", "AA", "AA+", "AAA-", "AAA", "AAA+"

- instrumentName: STRING，债券名称
- listingDate: TEMPORAL，上市日期
- market: STRING，市场代码

返回值：
返回操作结果信息

示例：
bond = "{\"productType\": \"Cash\", \"assetType\": \"Bond\", \"bondType\": \"FixedRateBond\", \"version\": 0, \"instrumentId\": \"250015.IB\", \"start\": \"2025.01.15\", \"maturity\": \"2028.01.15\", \"issuePrice\": 100.0, \"coupon\": 0.025, \"frequency\": \"Annual\", \"dayCountConvention\": \"ActualActualISDA\", \"currency\": \"CNY\", \"subType\": \"TREASURY_BOND\"}"
instrumentName = "25国债15"
listingDate = "2025.01.15"
market = "IB"
'

// save_instrument MCP 工具（简化版）- 修正版
def save_instrument_new_wrapper(bond, instrumentName, listingDate, market) {
        // 解析债券JSON
        bondDict = fromStdJson(bond)
        
        // 检查是否已存在
        checkSql = 'select instrumentId, instrumentName, instrument from loadTable("dfs://ficc_data2", "instrument") where instrumentId = "' + bondDict["instrumentId"] + '"'
        checkResult = parseExpr(checkSql).eval()
        
        if (size(checkResult) > 0) {
            // 记录已存在，直接返回现有记录的详细信息
            existingInstrument = checkResult.instrument[0]
            instrumentDict = extractInstrument(existingInstrument)
            
            result = dict(`status`message`instrumentId`instrumentDict, 
                         ["exists", "债券已存在，返回现有记录", bondDict["instrumentId"], instrumentDict])
        } else {
            // 记录不存在，插入新记录
            // 使用parseInstrument解析为结构化数据
            instrumentObj = parseInstrument(bondDict)
            
            // 提取instrument详细信息
            instrumentDict = extractInstrument(instrumentObj)
            
            // 准备插入数据
            insertData = table(
                [bondDict["instrumentId"]] as instrumentId,
                [instrumentName] as instrumentName,
                [bondDict["assetType"]] as assetType,
                [date(listingDate)] as listingDate,
                [market] as market,
                [instrumentObj] as instrument,
                "test" as extra
            )
            
            // 插入新记录
            instrumentTb = loadTable("dfs://ficc_data2", "instrument")
            instrumentTb.append!(insertData)
            
            result = dict(`status`message`instrumentId`instrumentDict, 
                         ["inserted", "债券保存成功", bondDict["instrumentId"], instrumentDict])
        }
        
        return toStdJson(result)

}

// save_curve MCP 工具（简化版）
description_save_curve_new = '
用于将市场数据曲线解析并存储到数据库的curve表中。

参数说明：
- curveData: STRING，JSON格式的曲线数据，包含以下字段：
  * mktDataType: STRING，固定填 "Curve"
  * referenceDate: DATE，参考日期
  * version: INT，版本号，默认值 0
  * curveType: STRING，固定填 "IrYieldCurve"
  * dayCountConvention: STRING，曲线的日期计数惯例，可选值：
    - "Actual360"：实际天数除以360
    - "Actual365"：实际天数除以365（不区分闰年）
    - "ActualActualISMA"：实际天数/实际天数（ISMA规则）
    - "ActualActualISDA"：实际天数/实际天数（ISDA规则）
  * interpMethod: STRING，内插方法，可选值：
    - "Linear"：线性插值
    - "CubicSpline"：三次样条插值
    - "CubicHermiteSpline"：三次埃尔米特样条插值
  * extrapMethod: STRING，外插方法，可选值：
    - "Flat"：平插
    - "Linear"：线性插值
  * dates: DATE[]，数据点的日期
  * values: DOUBLE[]，数据点的值，与dates中的元素一一对应
  * curveName: STRING，曲线名称（可选）
  * currency: STRING，货币，可选值："CNY", "USD", "EUR", "GBP", "JPY", "HKD"
  * compounding: STRING，复利类型，可选值：
    - "Simple"：单利
    - "Compounded"：离散复利
    - "Continuous"：连续复利
  * settlement: DATE，结算日（可选）
  * frequency: STRING，计息频率（可选），可选值：
    - "NoFrequency"：无效计息频率
    - "Once"：到期一次还本付息
    - "Annual"：每年付息一次
    - "Semiannual"：每半年付息一次
    - "EveryFourthMonth"：每四个月付息一次
    - "Quarterly"：每季度付息一次
    - "BiMonthly"：每两月付息一次
    - "Monthly"：每月付息一次
    - "EveryFourthWeek"：每四周付息一次
    - "BiWeekly"：每两周付息一次
    - "Weekly"：每周付息一次
    - "Daily"：每日付息一次
    - "Other"：其他计息频率
  * curveModel: STRING，曲线构建模型（可选），可选值："Bootstrap"（默认）, "NS", "NSS"
  * curveParams: DICT，模型的参数（当curveModel为"NS"或"NSS"时必填）

返回值：
返回操作结果信息

示例：
curveData = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.08.18\", \"currency\": \"CNY\", \"curveName\": \"CNY_TREASURY_BOND\", \"dayCountConvention\": \"ActualActualISDA\", \"compounding\": \"Compounded\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.09.18\", \"2025.11.18\"], \"values\": [0.013, 0.0137]}"
'


// save_curve MCP 工具（简化版）- 修正版
def save_curve_new_wrapper(curveData) {

    // 解析曲线JSON
    curveDict = fromStdJson(curveData)
    
    // 从字典中提取信息
    referenceDate = curveDict["referenceDate"]
    curveName = curveDict["curveName"]
    curveType = curveDict["curveType"]
    
    // 检查是否已存在
    checkSql = 'select referenceDate, curveName, marketData from loadTable("dfs://ficc_data2", "curve") where referenceDate = ' + string(date(referenceDate)) + ' and curveName = "' + curveName + '"'
    checkResult = parseExpr(checkSql).eval()
    
    if (size(checkResult) > 0) {
        // 记录已存在，直接返回现有记录的详细信息
        existingMarketData = checkResult.marketData[0]
        marketDataDict = extractMktData(existingMarketData)
        
        result = dict(`status`message`curveName`referenceDate`marketDataDict, 
                        ["exists", "曲线已存在，返回现有记录", curveName, string(date(referenceDate)), marketDataDict])
    } else {
        // 记录不存在，插入新记录
        // 使用parseMktData解析为结构化数据
        marketDataObj = parseMktData(curveDict)
        
        // 提取marketData详细信息
        marketDataDict = extractMktData(marketDataObj)
        
        // 准备插入数据
        insertData = table(
            [date(referenceDate)] as referenceDate,
            [curveName] as curveName,
            [curveType] as curveType,
            [marketDataObj] as marketData
        )
        
        // 插入到数据库表
        curveTb = loadTable("dfs://ficc_data2", "curve")
        curveTb.append!(insertData)
        
        result = dict(`status`message`curveName`referenceDate`marketDataDict, 
                        ["inserted", "曲线保存成功", curveName, string(date(referenceDate)), marketDataDict])
    }
    
    return toStdJson(result)
}


// 注册新的MCP工具
if (`save_instrument_new in (exec name from listMCPTools())) {
    updateMCPTool(`save_instrument_new, save_instrument_new_wrapper,
        `bond`instrumentName`listingDate`market,
        ["STRING", "STRING", "TEMPORAL", "STRING"],
        description_save_instrument_new)
} else {
    addMCPTool(`save_instrument_new, save_instrument_new_wrapper,
        `bond`instrumentName`listingDate`market,
        ["STRING", "STRING", "TEMPORAL", "STRING"],
        description_save_instrument_new)
}

if (`save_curve_new in (exec name from listMCPTools())) {
    updateMCPTool(`save_curve_new, save_curve_new_wrapper,
        [`curveData],
        ["STRING"],
        description_save_curve_new)
} else {
    addMCPTool(`save_curve_new, save_curve_new_wrapper,
        [`curveData],
        ["STRING"],
        description_save_curve_new)
}

// 发布工具
publishMCPTools(`save_instrument_new`save_curve_new)


// bond_pricer MCP 工具（新版本）
description_bond_pricer_new = '
用于对单只债券进行定价，支持筛选条件和直接输入债券/曲线数据两种方式。

参数说明：
- instrumentWhere: STRING，筛选instrument表的WHERE条件，如"instrumentId = \"250015.IB\""
    债券筛选可用列：
    - instrumentId（优先）：债券代码
    - instrumentName：债券名称
    - assetType：资产类型
    - listingDate：上市日期
    - market：市场代码


- curveWhere: STRING，筛选curve表的WHERE条件（必须包括referenceDate），如"curveName = \"CNY_TREASURY_BOND\" and referenceDate = 2025.04.01"
    曲线筛选可用列：
    - referenceDate（优先）：参考日期
    - curveName（优先）：曲线名称
    - curveType：曲线类型

- pricingDate: TEMPORAL，定价日期，应该和curveWhere 中的 referenceDate 相同

- bond: STRING，JSON格式的债券定义（可选），如果为空字符串""则从数据库筛选，包含以下字段：
  * mktDataType: STRING，固定填 "Curve"
  * curveType: STRING，固定填 "IrYieldCurve"
  * referenceDate: TEMPORAL，参考日期
  * currency: STRING，货币
  * curveName: STRING，曲线名称（可选）
  * dayCountConvention: STRING，日期计数惯例
  * compounding: STRING，复利类型，可选值："Simple", "Compounded", "Continuous"
  * interpMethod: STRING，内插方法，可选值："Linear", "CubicSpline", "CubicHermiteSpline"
  * extrapMethod: STRING，外插方法，可选值："Flat", "Linear"
  * frequency: STRING，计息频率
  * dates: DATE[]，数据点的日期
  * values: DOUBLE[]，数据点的值

- curveData: STRING，JSON格式的曲线数据（可选），如果为空字符串""则从数据库筛选，，包含以下字段：
  * mktDataType: STRING，固定填 "Curve"
  * curveType: STRING，固定填 "IrYieldCurve"
  * referenceDate: TEMPORAL，参考日期
  * currency: STRING，货币
  * curveName: STRING，曲线名称（可选）
  * dayCountConvention: STRING，日期计数惯例
  * compounding: STRING，复利类型，可选值："Simple", "Compounded", "Continuous"
  * interpMethod: STRING，内插方法，可选值："Linear", "CubicSpline", "CubicHermiteSpline"
  * extrapMethod: STRING，外插方法，可选值："Flat", "Linear"
  * frequency: STRING，计息频率
  * dates: DATE[]，数据点的日期
  * values: DOUBLE[]，数据点的值

- spreadCurve: STRING，JSON格式的信用利差曲线定义（可选），传空字符串""表示不使用，结构与discountCurve相同

- setting: STRING，JSON格式的设置字典（可选），传空字符串""表示只计算NPV，包含以下键：
  * calcDiscountCurveDelta: BOOL，是否计算债券对贴现曲线的一阶敏感度
  * calcDiscountCurveGamma: BOOL，是否计算债券对贴现曲线的二阶敏感度
  * calcDiscountCurveKeyRateDuration: BOOL，是否计算债券的关键利率久期
  * discountCurveShift: DOUBLE，贴现曲线的平行扰动，如0.0001
  * discountCurveKeyTerms: DOUBLE[]，关键期限年数，如[1.0, 3.0, 5.0]
  * discountCurveKeyShifts: DOUBLE[]，关键期限的扰动幅度，如[0.0001, 0.0002, 0.0015]

返回值：
如果筛选结果不为1条记录，返回筛选结果信息；如果为1条记录，返回定价结果

示例1（使用筛选条件）：
instrumentWhere = "instrumentId = \"220019.IB\""
curveWhere = "curveName = \"SQS_CNY_TREASURY_BOND\" and referenceDate = 2025.04.01"
pricingDate = "2025.04.01"
bond = ""
curveData = ""
spreadCurve = ""
setting = ""

示例2（直接输入数据）：
instrumentWhere = ""
curveWhere = ""
pricingDate = "2025.04.01"
bond = "{\"productType\": \"Cash\", \"assetType\": \"Bond\", \"bondType\": \"FixedRateBond\", \"instrumentId\": \"250015.IB\", \"start\": \"2025.01.15\", \"maturity\": \"2028.01.15\", \"coupon\": 0.025, \"frequency\": \"Annual\", \"dayCountConvention\": \"ActualActualISDA\"}"
curveData = "{\"mktDataType\": \"Curve\", \"curveType\": \"IrYieldCurve\", \"referenceDate\": \"2025.04.01\", \"currency\": \"CNY\", \"curveName\": \"CNY_TREASURY_BOND\", \"dayCountConvention\": \"ActualActualISDA\", \"compounding\": \"Compounded\", \"interpMethod\": \"Linear\", \"extrapMethod\": \"Flat\", \"frequency\": \"Annual\", \"dates\": [\"2025.05.01\", \"2026.04.01\"], \"values\": [0.025, 0.03]}"
spreadCurve = ""
setting = ""
'

def bond_pricer_new_wrapper(instrumentWhere, curveWhere, pricingDate, bond, curveData, spreadCurve, setting) {
    bondObj = NULL
    curveObj = NULL
    
    // 处理债券数据
    if (bond != "" && !isNull(bond)) {
        // 直接使用输入的债券数据
        bondDict = fromStdJson(bond)
        bondObj = parseInstrument(bondDict)
    } else if (instrumentWhere != "" && !isNull(instrumentWhere)) {
        // 从数据库筛选债券
        instrumentSql = 'select instrumentId, instrumentName, assetType, listingDate, market from loadTable("dfs://ficc_data2", "instrument") where ' + instrumentWhere
        instrumentResult = parseExpr(instrumentSql).eval()
        
        if (size(instrumentResult) == 0) {
            return "未找到匹配的债券记录，筛选条件: " + instrumentWhere
        } else if (size(instrumentResult) > 1) {
            return "找到多条债券记录(" + string(size(instrumentResult)) + "条)，请使用更精确的筛选条件。前10条匹配记录:\n" + toStdJson(select * from instrumentResult limit 10)
        } else {
            // 获取完整的instrument数据
            fullInstrumentSql = 'select instrument from loadTable("dfs://ficc_data2", "instrument") where ' + instrumentWhere
            fullInstrumentData = parseExpr(fullInstrumentSql).eval()
            bondObj = fullInstrumentData.instrument[0]
        }
    } else {
        return "请提供债券筛选条件或直接输入债券数据"
    }
    
    // 处理曲线数据
    if (curveData != "" && !isNull(curveData)) {
        // 直接使用输入的曲线数据
        curveDict = fromStdJson(curveData)
        curveObj = parseMktData(curveDict)
    } else if (curveWhere != "" && !isNull(curveWhere)) {
        // 从数据库筛选曲线

        curveSql = 'select referenceDate, curveName, curveType from loadTable("dfs://ficc_data2", "curve") where ' + curveWhere
        curveResult = parseExpr(curveSql).eval()
        
        if (size(curveResult) == 0) {
            return "未找到匹配的曲线记录，筛选条件: " + curveWhere
        } else if (size(curveResult) > 1) {
            return "找到多条曲线记录(" + string(size(curveResult)) + "条)，请使用更精确的筛选条件。前10条匹配记录:\n" + toStdJson(select * from curveResult limit 10)
        } else {
            // 获取完整的curve数据
            fullCurveSql = 'select referenceDate, curveName, curveType, marketData from loadTable("dfs://ficc_data2", "curve") where ' + curveWhere
            fullCurveData = parseExpr(fullCurveSql).eval()
            curveObj = fullCurveData.marketData[0]
        }
    } else {
        return "请提供曲线筛选条件或直接输入曲线数据"
    }
    
    // 处理利差曲线参数
    spreadCurveObj = NULL
    if (spreadCurve != "" && !isNull(spreadCurve)) {
        spreadCurveObj = parseMktData(fromStdJson(spreadCurve))
    }
    
    // 转换定价日期
    pricingDateObj = date(pricingDate)
    
    // 处理设置参数并进行定价
    if (setting == "" || isNull(setting)) {
        // 只计算NPV
        if (spreadCurveObj == NULL) {
            result = bondPricer(bondObj, pricingDateObj, curveObj)
        } else {
            result = bondPricer(bondObj, pricingDateObj, curveObj, spreadCurveObj)
        }
        return "定价结果 (NPV): " + string(result)
    } else {
        // 计算NPV和风险指标
        settingObj = fromStdJson(setting)
        if (spreadCurveObj == NULL) {
            result = bondPricer(bondObj, pricingDateObj, curveObj, setting=settingObj)
        } else {
            result = bondPricer(bondObj, pricingDateObj, curveObj, spreadCurveObj, settingObj)
        }
        return "定价结果: " + toStdJson(result)
    }
}

if (`bond_pricer_new in (exec name from listMCPTools())) {
    updateMCPTool(`bond_pricer_new, bond_pricer_new_wrapper,
        `instrumentWhere`curveWhere`pricingDate`bond`curveData`spreadCurve`setting,
        ["STRING", "STRING", "TEMPORAL", "STRING", "STRING", "STRING", "STRING"],
        description_bond_pricer_new)
} else {
    addMCPTool(`bond_pricer_new, bond_pricer_new_wrapper,
        `instrumentWhere`curveWhere`pricingDate`bond`curveData`spreadCurve`setting,
        ["STRING", "STRING", "TEMPORAL", "STRING", "STRING", "STRING", "STRING"],
        description_bond_pricer_new)
}


publishMCPTools(`bond_pricer_new)
// 发布所有工具
