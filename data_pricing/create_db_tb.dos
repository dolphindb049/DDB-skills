//========== 1. 创建FICC数据库 ==========
create database "dfs://ficc_data2"
partitioned by VALUE(2020.01M..2030.12M), HASH([SYMBOL, 100])
engine="TSDB",
atomic="TRANS"

//========== 2. 创建债券基本信息表 ==========
CREATE TABLE "dfs://ficc_data2"."bond_basic_info" (
    secID SYMBOL [comment="证券代码"],
    ticker SYMBOL [comment="代码"],
    exchangeCD SYMBOL [comment="交易所代码"],
    bondID INT [comment="债券ID"],
    secFullName STRING [comment="证券全称"],
    secShortName STRING [comment="证券简称"],
    listStatusCD SYMBOL [comment="上市状态"],
    partyID INT [comment="发行人ID"],
    issuer STRING [comment="发行人"],
    totalSize DOUBLE [comment="发行总量(亿)"],
    remainSize DOUBLE [comment="存续总量(亿)"],
    currencyCD SYMBOL [comment="币种"],
    couponTypeCD SYMBOL [comment="付息类型"],
    cpnFreqCD SYMBOL [comment="付息频率"],
    paymentCD SYMBOL [comment="付息方式"],
    coupon DOUBLE [comment="票面利率(%)"],
    par INT [comment="面值"],
    hybridCD SYMBOL [comment="混合债券标识"],
    typeID SYMBOL [comment="分类ID"],
    typeName STRING [comment="分类名称"],
    publishDate DATE [comment="公告日期"],
    listDate DATE [comment="上市日期"],
    delistDate DATE [comment="摘牌日期"],
    firstAccrDate DATE [comment="起息日"],
    maturityDate DATE [comment="到期日"],
    firstRedempDate DATE [comment="兑付日"],
    isOption INT [comment="是否含期权"],
    absLevelRatio DOUBLE [comment="绝对评级比例"],
    actMaturityDate DATE [comment="实际到期日"],
    frnCurrBmkRate SYMBOL [comment="浮动利率基准"],
    absIssuerID INT [comment="ABS发行人ID"],
    absIssuer STRING [comment="ABS发行人"],
    absLevelCD SYMBOL [comment="绝对评级"],
    frnRefRateCD SYMBOL [comment="基准利率代码"],
    frnMargin SYMBOL [comment="浮动利差"],
    privPlacemFlag SYMBOL [comment="私募标识"]
)
partitioned by publishDate, secID,
sortColumns = `secID`publishDate
comment = "债券基本信息表"

//========== 3. 导入债券基本信息数据 ==========
// 重新提取并修改schema
schema = extractTextSchema("/hdd/hdd9/jrzhang/projects/ficc/bond_basic_info.csv");

// 修改数据类型以匹配目标表
update schema set type = `SYMBOL where name in [`ticker, `paymentCD, `hybridCD];
update schema set type = `STRING where name in [`secFullName, `secShortName, `issuer, `typeName, `absIssuer];
update schema set type = `INT where name in [`bondID, `partyID, `par, `absIssuerID];

// 加载数据
bond_data = loadText("/hdd/hdd9/jrzhang/projects/ficc/bond_basic_info.csv", schema=schema);



// 导入到分布式表
loadTable("dfs://ficc_data2", "bond_basic_info").append!(SELECT * FROM bond_data WHERE publishDate>=2022.01.01);

// 检查导入结果
select count(*) as total_records from loadTable("dfs://ficc_data2", "bond_basic_info")

truncate("dfs://ficc_data2", "bond_basic_info")
//========== 4. 创建其他表结构 ==========
// 创建金融工具表
CREATE TABLE "dfs://ficc_data2"."instrument" (
    instrumentId STRING [comment="金融工具ID"],
    instrumentName STRING [comment="金融工具名称"],
    assetType STRING [comment="资产类型"],
    listingDate DATE [comment="上市日期"],
    market SYMBOL [comment="市场代码"],
    instrument INSTRUMENT [comment="金融工具类型"],
    extra BLOB
)
PARTITIONED BY listingDate, assetType
sortColumns = `instrumentId`assetType`listingDate


// 创建收益率曲线表
CREATE TABLE "dfs://ficc_data2"."bond_yield_curve" (
    date DATE [comment="日期"],
    curveName STRING [comment="曲线名称"],
    term DOUBLE [comment="期限"],
    spotYield DOUBLE [comment="收益率"]
)
PARTITIONED BY date, curveName
sortColumns = `date
comment = "收益率曲线"

// 创建曲线表
CREATE TABLE "dfs://ficc_data2"."curve" (
    referenceDate DATE [comment="参考日期"],
    curveName STRING [comment="曲线名称"],
    curveType STRING [comment="曲线类型"],
    marketData MKTDATA [comment="市场数据"]
)
PARTITIONED BY referenceDate,curveType
sortColumns = `curveName`referenceDate
comment = "曲线表"


// 创建国债期货最便宜可交割券表
CREATE TABLE "dfs://ficc_data2"."FutuCtd" (
    col0           INT   [comment=""],
    secID          SYMBOL   [comment="通联编制的证券编码"],
    ticker         SYMBOL   [comment="通用交易代码"],
    secShortName   STRING   [comment="证券简称"],
    exchangeCD     SYMBOL   [comment="交易市场代码"],
    tradeDate      DATE     [comment="交易日期"],
    bondID         SYMBOL   [comment="债券ID"],  
    shSecID        STRING   [comment="沪市债券证券内部ID"],
    shTicker       SYMBOL   [comment="沪市债券通用交易代码"],
    shSecShortName STRING   [comment="沪市债券简称"],
    shIrr          DOUBLE   [comment="沪市隐含回购利率"],
    szSecID        STRING   [comment="深市债券证券内部ID"],
    szTicker       INT      [comment="深市债券通用交易代码"],
    szSecShortName STRING   [comment="深市债券简称"],
    szIrr          DOUBLE   [comment="深市隐含回购利率"],
    ibSecID        STRING   [comment="银行间债券证券内部ID"],
    ibTicker       SYMBOL   [comment="银行间债券通用交易代码"],
    ibSecShortName STRING   [comment="银行间债券简称"],
    ibIrr          DOUBLE   [comment="银行间隐含回购利率"],
    ctdSecID       STRING   [comment="最便宜可交割债券证券内部ID"],
    ctdIrr         DOUBLE   [comment="最便宜隐含回购利率"],
    updateTime     DATETIME [comment="更新时间"]
)
PARTITIONED BY tradeDate,exchangeCD
sortColumns = `secID`tradeDate
comment = "国债期货最便宜可交割券表";

// truncate("dfs://ficc_data2", "instrument")
//========== 4. 导入债券数据和曲线数据 ==========
def getBondType(couponType){
    return iif(couponType=='FLOAT','FloatingRate',iif(couponType=='FIXED',
    'FixedRate',iif(couponType=='ZERO','DiscountBond','ZeroCouponBond')))
}
def getfreq(freq){
    return iif(freq=="MAT",0, iif(freq=="1PY", 1, iif(freq == "2PY", 2, iif(freq == "4PY", 4, 
    iif(freq == "6PY", 6, iif(freq == "12PY", 12, iif(freq == "24PY", 24, -1)))))))
}
def getBondSubType(typeName, issuer) {
    bond_type_map = {
        "超短期融资券": "SHORT_FIN_BOND",
        "证券公司短期融资券": "SHORT_FIN_BOND",
        "资产支持票据": "ABS",
        "一般中期票据": "MTN",
        "同业存单": "NCD",
        "私募公司债": "PPN",
        "证券公司债": "CORP_BOND",
        "券商专项资产管理": "ABS",
        "地方政府债": "LOC_GOV_BOND",
        "汽车抵押贷款证券化": "ABS",
        "信贷资产证券化": "ABS",
        "住房抵押贷款证券化": "ABS",
        "国债": "TREASURY_BOND",
        "商业银行普通债": "COMM_BANK_FIN_BOND",
        "一般企业债": "CORP_BOND",
        "股权交易中心债": "CORP_BOND",
        "一般公司债": "CORP_BOND",
        "证券公司次级债": "CORP_BOND",
        "其它金融机构次级债券": "CORP_BOND",
        "政府支持机构债": "CORP_BOND",
        "可转债": "CORP_BOND",
        "定向工具": "PPN",
        "政策性银行债": "CDB_BOND",   
        "中央国库现金管理": "TREASURY_BOND",
        "保险公司债": "CORP_BOND",
        "集合中期票据": "MTN",
        "一般短期融资券": "SHORT_FIN_BOND",
        "可交换债券": "CORP_BOND",
        "项目收益票据": "CORP_BOND",
        "其它金融债": "COMM_BANK_FIN_BOND",
        "公司债": "CORP_BOND",
        "二级资本工具": "BANK_SUB_CAP_BOND",
        "商业银行次级债": "BANK_SUB_CAP_BOND",
        "无固定期限资本债券": "BANK_SUB_CAP_BOND",
        "国际机构债": "CORP_BOND",
        "自贸区离岸债券": "CORP_BOND",
        "集合企业债": "CORP_BOND",
        "央行票据": "CENTRAL_BANK_BILL",
        "政策性银行次级债": "BANK_SUB_CAP_BOND"
    }
    specialIssuer = ["国家开发银行", "中国进出口银行", "中国农业发展银行"]
    return iif(typeName!="政策性银行债", bond_type_map[typeName].flatten(), 
    iif(issuer == "国家开发银行", "CDB_BOND", iif(issuer == "中国进出口银行", "EIBC_BOND", "ADBC_BOND")))
}


mapping = dict(STRING, ANY)
mapping["start"] = <firstAccrDate as start>
mapping["maturity"] = <maturityDate as maturity>
mapping["currency"] = <currencyCD as currency>
mapping["bondType"] = <getBondType(couponTypeCD) as bondType>
mapping["frequency"] = <getfreq(cpnFreqCD) as frequency>
mapping["coupon"] = <coupon/100 as coupon>
mapping["nominal"] = <par as nominal>
mapping["instrumentId"] = <secID as instrumentId>
mapping["productType"] = <"Cash" as productType>
mapping["assetType"] = <"Bond" as assetType>
mapping["dayCountConvention"] = <"ActualActualISDA" as dayCountConvention>
mapping["subType"] = <getBondSubType(typeName, issuer) as subType>
mapping["instrumentName"] = <secShortName as instrumentName>
mapping["exchangeCD"] = <exchangeCD as exchangeCD>
// otherColumns = loadTable("dfs://ficc_data2", "bond_basic_info").columnNames()
// otherColumns = each(sqlCol{,,}, otherColumns,, otherColumns + "_extra")

//原始数据导入
fixedBondTb = select * from loadTable("dfs://ficc_data2", "bond_basic_info") 
where typeID.startsWith("020201") and couponTypeCD = "FIXED" 
and listStatusCD not in ["DE", "UN"] and paymentCD != "P"
//转换为parseInstrument所需格式
fixedBondTb = sql(select = mapping.values(), 
from = fixedBondTb).eval()

//批量解析
def importFixedBond(fixedBondTb) {
    instrumentTb = loadTable("dfs://ficc_data2","instrument")
    resultTb = table(1:0, instrumentTb.columnNames(), instrumentTb.schema().colDefs.typeString)
    failedSecIds = table(1:0, ["instrumentId", "error"], [STRING, STRING])
    for (ins in fixedBondTb) {  // ins = fixedBondTb[3]
        try{
            instrumentTmp = array(INSTRUMENT)
            instrumentTmp.append!(parseInstrument(ins))
            tmp = table(ins.instrumentId as instrumentId, ins.instrumentName as instrumentName, 
            "Bond" as assetType, ins.start as startDate, ins.exchangeCD as market,
            instrumentTmp, string(NULL) as extra)
            resultTb.append!(tmp)
        } catch(ex) {
            failedSecIds.append!(table(ins.instrumentId as instrumentId, ex[0] + ex[1] as error))
        }
    }
    return resultTb, failedSecIds
}

instrument_tb = loadTable("dfs://ficc_data2","instrument")
instrument_tb.append!(importFixedBond(fixedBondTb)[0])

