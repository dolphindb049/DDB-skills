    "无担保企业债(AAA(2))": "CNY_UNSECURED_CORP_AAA",
    "有担保企业债(AA)": "CNY_CORP_AA",
    "有担保企业债(AA+)": "CNY_CORP_AA+",
    "有担保企业债(AA-)": "CNY_CORP_AA-",
    "有担保企业债(AAA)": "CNY_CORP_AAA",
    "有担保企业债(AAA+)": "CNY_CORP_AAA+",
    "证券公司短期融资券(AA)": "CNY_SC_FIN_BILL_AA",
    "证券公司短期融资券(AA+)": "CNY_SC_FIN_BILL_AA+",
    "证券公司短期融资券(AAA)": "CNY_SC_FIN_BILL_AAA",
    "资产支持证券(AA+)": "CNY_ABS_AA+",
    "资产支持证券(AAA)": "CNY_ABS_AAA",
    "资产支持证券(AAA-)": "CNY_ABS_AAA-",
    "非公开发行债(AA)": "CNY_PPN_AA",
    "非公开发行债(AA+)": "CNY_PPN_AA+",
    "非公开发行债(AA-)": "CNY_PPN_AA-",
    "非公开发行债(AAA)": "CNY_PPN_AAA",
    "非公开发行债(AAA-)": "CNY_PPN_AAA-",
    "政策性金融债(LPR_1Y)浮动利率点差": ""
}

// 形成dates和values列表
curveName=exec distinct curveName from loadTable("dfs://ficc_data2","bond_yield_curve")
curveName=curveName.flatten()
date=exec distinct date from loadTable("dfs://ficc_data2","bond_yield_curve") 
date=date.flatten().distinct()


for (j in date){
    for (i in curveName){
        // 处理到期数据
        temp=select * from loadTable("dfs://ficc_data2","bond_yield_curve") where date==j and curveName==i and spotYield !=NULL and term !=0
        if (count(temp)>0){
            temp=select * from temp context by term limit -1
            temp=select date,curveName, cast(term*365,int) as term , spotYield from temp
            temp=select date,curveName,term, temporalAdd(j,term,"d") as dates , spotYield from temp order by dates
            temp=select toArray(dates) as dates, toArray(spotYield/100) as values from temp group by date
            cName=curveNameDict[i]
            curve = {
            "mktDataType": "Curve",
            "curveType": "IrYieldCurve",
            "referenceDate": j,
            "dayCountConvention": "ActualActualISDA",
            "curveName": cName,
            "currency": "CNY",
            "compounding": "Compounded",
            "interpMethod": "Linear",
            "extrapMethod": "Flat",
            "frequency": "Annual",
            "dates":temp.dates.flatten(),
            "values":temp.values.flatten()
            }
            mktData = parseMktData(curve)
            test=select date as referenceDate, cName as curveName , "IrYieldCurve" as curveType, mktData as marketData from temp
            loadTable("dfs://ficc_data2", "curve").append!(test)
        }
    }
}

// =========================  导入国债期货数据 =======================

temp=remoteRun(conn,'select * from loadTable("dfs://instrument_dbtest2","FutuCtd")')
loadTable("dfs://ficc_data2","FutuCtd").append!(temp)

// ================================
// 完整的条件触发计算引擎示例代码
// ================================
// ================================
// 完整的条件触发计算引擎示例代码
// ================================

// 1. 创建输入数据流表
share streamTable(1:0, `timestamp`deviceId`metricsName`RmetricValue, 
    [TIMESTAMP, SYMBOL, SYMBOL, DOUBLE]) as sensorData

// 2. 创建状态事件输出表  
share table(1000:0, `deviceId`metricsName`timestamp`eventB`eventC, 
    [SYMBOL, SYMBOL, TIMESTAMP, BOOL, BOOL]) as stateEvents

// 3. 创建响应式状态引擎，根据metricsName进行不同计算
stateEngine = createReactiveStateEngine(
    name="conditionalEngine",
    metrics=<[
        timestamp,
        // 事件B：只对A001计算连续3次增量为1
        iif(metricsName == "A001", 
            msum(deltas(RmetricValue) == 1, 3) == 3, 
            false),
        // 事件C：只对R131计算连续3次大于-40  
        iif(metricsName == "R131", 
            msum(RmetricValue > -40, 3) == 3, 
            false)
    ]>,
    dummyTable=sensorData,
    outputTable=stateEvents,
    keyColumn=["deviceId", "metricsName"]
)

// 4. 订阅流表
subscribeTable(tableName=`sensorData, actionName="conditionalEngine", 
    handler=tableInsert{stateEngine})

// 5. 准备测试数据
testData = table(
    2024.01.01T10:00:01..2024.01.01T10:00:13 as timestamp,
    take("DEV001", 13) as deviceId,
    [9, 10, 11, 12, NULL, NULL, NULL, 12, 13, 14, 15, NULL, NULL] as A001,  
    [NULL, NULL, NULL, NULL, -30, NULL, NULL, NULL, NULL, NULL, -35, -20, -15] as R131,  
    [NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, 5, 50] as R134
)

// 6. 转换为长格式数据
testDataLong = select timestamp, deviceId, valueType as metricsName, value as RmetricValue
from unpivot(testData, `timestamp`deviceId, `A001`R131`R134)
where value is not null
order by timestamp

// 7. 插入测试数据
sensorData.append!(testDataLong)

// 8. 等待计算完成并查看结果
sleep(1)
results = select * from stateEvents order by timestamp, metricsName

// 9. 清理资源
unsubscribeTable("", "sensorData", "conditionalEngine")
dropStreamEngine("conditionalEngine")

// 输出最终结果（必须是最后一行，不能用print）
results