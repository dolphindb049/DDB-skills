res = dict(STRING, ANY)

try {
    db1 = database("dfs://stockMinKSH")
    res["stockMinKSH_dir"] = db1.getDir()
    res["stockMinKSH_tables"] = db1.getTableName()
} catch(ex) {
    res["stockMinKSH_meta_error"] = string(ex)
}

try {
    db2 = database("dfs://stock_daily")
    res["stock_daily_dir"] = db2.getDir()
    res["stock_daily_tables"] = db2.getTableName()
} catch(ex) {
    res["stock_daily_meta_error"] = string(ex)
}

res
